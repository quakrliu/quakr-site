---
interface Props {
  slot?: string;
  format?: 'auto' | 'fluid' | 'rectangle';
  layout?: string;
}

const { format = 'auto', layout } = Astro.props;
---

<div class="ad-container">
  <ins class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-9139712987155828"
    data-ad-slot="auto"
    data-ad-format={format}
    data-full-width-responsive="true"
    {...(layout ? { 'data-ad-layout': layout } : {})}
  ></ins>
  <script is:inline>
    (adsbygoogle = window.adsbygoogle || []).push({});
  </script>
</div>

<style>
  .ad-container {
    margin: 2rem 0;
    min-height: 90px;
    text-align: center;
  }
</style>
