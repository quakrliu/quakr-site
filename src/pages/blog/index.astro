---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const now = new Date();
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.pubDate <= now);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="All Articles" description="Browse all Passive Yield Lab guides on crypto passive income, AI income, and smart yield strategies.">
  <div class="page-content">
    <h1>All Articles</h1>
  </div>

  <section class="article-grid">
    {posts.map((post) => (
      <a href={`/blog/${post.id}`} class="article-card">
        <span class="card-category">{post.data.category}</span>
        <h3>{post.data.title}</h3>
        <p>{post.data.description}</p>
        <div class="card-meta">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })}
          </time>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>
