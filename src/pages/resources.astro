---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Recommended Crypto Tools & Platforms"
  description="Trusted crypto exchanges, tax tools, and staking platforms recommended by Passive Yield Lab. All vetted and reviewed."
  ogImage="/og/default.svg"
>
  <!-- Hero -->
  <div class="resources-hero">
    <div class="resources-hero-inner">
      <span class="resources-label">Resources</span>
      <h1>Recommended Tools &amp; Platforms</h1>
      <p>
        Every platform and tool mentioned on Passive Yield Lab — vetted, reviewed, and linked for your convenience.
      </p>
    </div>
  </div>

  <div class="resources-page">

    <!-- Affiliate Disclosure Banner -->
    <div class="affiliate-disclosure resources-disclosure">
      <strong>Affiliate Disclosure:</strong> Some links on this page are affiliate links. If you sign up through them, we may earn a commission at no extra cost to you. We only recommend platforms we've personally evaluated. See our full <a href="/disclaimer">Disclaimer</a>.
    </div>

    <!-- Section 1: Crypto Exchanges -->
    <section class="resources-section">
      <h2 class="resources-section-title">
        <span class="resources-section-icon">⇄</span>
        Crypto Exchanges
      </h2>
      <p class="resources-section-desc">
        The exchanges we trust for trading, staking, and earning crypto passive income.
      </p>

      <div class="resources-grid">

        <!-- Binance -->
        <div class="resource-card">
          <div class="resource-card-header">
            <div class="resource-logo">BN</div>
            <div class="resource-card-meta">
              <h3>Binance</h3>
              <span class="resource-tag">Exchange</span>
            </div>
          </div>
          <p class="resource-desc">
            The world's largest crypto exchange by volume. Offers spot trading, futures, staking, savings products, and Earn — all in one place. Low fees and deep liquidity make it the go-to for most crypto holders.
          </p>
          <a
            href="https://www.binance.com/en/register?ref=725285686"
            target="_blank"
            rel="noopener noreferrer sponsored"
            class="resource-cta-btn"
          >
            Get Started on Binance →
          </a>
        </div>

        <!-- OKX -->
        <div class="resource-card">
          <div class="resource-card-header">
            <div class="resource-logo">OKX</div>
            <div class="resource-card-meta">
              <h3>OKX</h3>
              <span class="resource-tag">Exchange</span>
            </div>
          </div>
          <p class="resource-desc">
            A top-tier global exchange with a powerful Web3 wallet, DeFi integrations, and competitive staking yields. OKX stands out for its on-chain tools and broad altcoin coverage.
          </p>
          <a
            href="https://www.okx.com/join/26575603"
            target="_blank"
            rel="noopener noreferrer sponsored"
            class="resource-cta-btn"
          >
            Join OKX →
          </a>
        </div>

        <!-- Bybit -->
        <div class="resource-card">
          <div class="resource-card-header">
            <div class="resource-logo">BB</div>
            <div class="resource-card-meta">
              <h3>Bybit</h3>
              <span class="resource-tag">Exchange</span>
            </div>
          </div>
          <p class="resource-desc">
            Known for derivatives and perpetual contracts, Bybit also offers a solid Earn section with flexible and fixed-term staking. Great for active traders who want passive income on the side.
          </p>
          <a
            href="https://www.bybit.com/invite?ref=WKNA1V"
            target="_blank"
            rel="noopener noreferrer sponsored"
            class="resource-cta-btn"
          >
            Sign Up on Bybit →
          </a>
        </div>

        <!-- Bitfinex -->
        <div class="resource-card">
          <div class="resource-card-header">
            <div class="resource-logo">BFX</div>
            <div class="resource-card-meta">
              <h3>Bitfinex</h3>
              <span class="resource-tag">Exchange</span>
            </div>
          </div>
          <p class="resource-desc">
            One of the oldest and most trusted exchanges, Bitfinex is the go-to for margin funding — you lend your idle USDT or BTC to traders and earn daily interest. Ideal for passive income seekers.
          </p>
          <a
            href="https://www.bitfinex.com/sign-up?refcode=VzaPAa8Lh"
            target="_blank"
            rel="noopener noreferrer sponsored"
            class="resource-cta-btn"
          >
            Try Bitfinex →
          </a>
        </div>

      </div>
    </section>

    <!-- Section 2: Tax & Portfolio Tools -->
    <section class="resources-section">
      <h2 class="resources-section-title">
        <span class="resources-section-icon">◈</span>
        Tax &amp; Portfolio Tools
      </h2>
      <p class="resources-section-desc">
        Keep your crypto taxes clean and your portfolio organized.
      </p>

      <div class="resources-grid resources-grid--single">

        <!-- CoinLedger -->
        <div class="resource-card resource-card--featured">
          <div class="resource-card-header">
            <div class="resource-logo resource-logo--green">CL</div>
            <div class="resource-card-meta">
              <h3>CoinLedger</h3>
              <span class="resource-tag resource-tag--green">Tax Tool</span>
            </div>
          </div>
          <p class="resource-desc">
            The easiest way to calculate your crypto taxes. CoinLedger connects to all major exchanges and wallets, auto-imports your transactions, and generates IRS-ready tax reports in minutes. Supports staking rewards, DeFi, NFTs, and more — no spreadsheet nightmares.
          </p>
          <a
            href="https://coinledger.io?fpr=4bsqmx"
            target="_blank"
            rel="noopener noreferrer sponsored"
            class="resource-cta-btn resource-cta-btn--green"
          >
            Calculate Your Crypto Taxes →
          </a>
        </div>

      </div>
    </section>

    <!-- Section 3: Free Tools -->
    <section class="resources-section">
      <h2 class="resources-section-title">
        <span class="resources-section-icon">⬡</span>
        Free Tools
      </h2>
      <p class="resources-section-desc">
        Built by Passive Yield Lab, free forever. No sign-up required.
      </p>

      <div class="resources-grid">

        <!-- Bear Market Survival Kit -->
        <div class="resource-card resource-card--featured">
          <div class="resource-card-header">
            <div class="resource-logo resource-logo--accent">PDF</div>
            <div class="resource-card-meta">
              <h3>Bear Market Survival Kit</h3>
              <span class="resource-tag resource-tag--accent">Free Guide</span>
            </div>
          </div>
          <p class="resource-desc">
            7 passive income strategies that work when prices drop. Real protocols, realistic numbers, and step-by-step instructions. Download the free 32-page PDF.
          </p>
          <a href="/resources/bear-market-survival-kit" class="resource-cta-btn">
            Get Free Guide &rarr;
          </a>
        </div>

        <!-- Staking Calculator -->
        <div class="resource-card resource-card--internal">
          <div class="resource-card-header">
            <div class="resource-logo resource-logo--accent">SC</div>
            <div class="resource-card-meta">
              <h3>Staking Calculator</h3>
              <span class="resource-tag resource-tag--accent">Free Tool</span>
            </div>
          </div>
          <p class="resource-desc">
            Estimate your staking rewards with our free calculator. Input your amount, APY, and compounding frequency — see exactly how much your crypto can earn over time. No email required.
          </p>
          <a href="/tools/staking-calculator" class="resource-cta-btn">
            Open Calculator →
          </a>
        </div>

        <!-- Newsletter -->
        <div class="resource-card resource-card--internal">
          <div class="resource-card-header">
            <div class="resource-logo resource-logo--accent">NL</div>
            <div class="resource-card-meta">
              <h3>Weekly Newsletter</h3>
              <span class="resource-tag resource-tag--accent">Free</span>
            </div>
          </div>
          <p class="resource-desc">
            Every week: the best crypto passive income opportunities, staking yield updates, and DeFi insights — straight to your inbox. No spam. Unsubscribe anytime.
          </p>
          <a
            href="https://passiveyieldlab.beehiiv.com/subscribe"
            target="_blank"
            rel="noopener noreferrer"
            class="resource-cta-btn"
          >
            Subscribe for Free →
          </a>
        </div>

      </div>
    </section>

    <!-- Disclaimer -->
    <section class="resources-disclaimer-section">
      <div class="resources-disclaimer-box">
        <h2>A Note on Affiliate Links</h2>
        <p>
          Some links on this page are affiliate links, marked with a small commission for Passive Yield Lab when you sign up. This comes at <strong>zero extra cost to you</strong> — in many cases you'll actually get a bonus or fee discount through our referral links.
        </p>
        <p>
          We only recommend platforms and tools that we have personally used, evaluated for security, and believe provide genuine value to crypto holders. Affiliate revenue helps us keep Passive Yield Lab free and independent.
        </p>
        <p>
          <strong>Nothing on this page is financial advice.</strong> Always do your own research before depositing funds on any platform. Crypto carries significant risk.
        </p>
        <a href="/disclaimer" class="resources-disclaimer-link">Read Our Full Disclaimer →</a>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* ===== Page Layout ===== */
  .resources-hero {
    position: relative;
    background: linear-gradient(180deg, rgba(74, 144, 217, 0.04) 0%, transparent 100%);
    border-bottom: 1px solid var(--border);
    padding: 3.5rem 1.5rem 3rem;
    text-align: center;
    overflow: hidden;
  }

  .resources-hero::before {
    content: '';
    position: absolute;
    top: -80px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 350px;
    background: radial-gradient(ellipse at center, rgba(74, 144, 217, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .resources-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
  }

  .resources-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    background: var(--accent-dim);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    margin-bottom: 1rem;
  }

  .resources-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4.5vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 0.85rem;
    color: var(--text-primary);
    text-wrap: balance;
  }

  .resources-hero p {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .resources-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  /* ===== Disclosure Banner ===== */
  .resources-disclosure {
    max-width: 100%;
    margin-bottom: 2.5rem;
    font-size: 0.83rem;
    line-height: 1.6;
  }

  .resources-disclosure a {
    color: #7A5B2E;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .resources-disclosure a:hover {
    color: #78350F;
  }

  /* ===== Section ===== */
  .resources-section {
    margin-bottom: 3.5rem;
  }

  .resources-section-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 0.35rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    letter-spacing: -0.02em;
  }

  .resources-section-icon {
    font-style: normal;
    color: var(--accent);
    font-size: 1.1rem;
  }

  .resources-section-desc {
    font-size: 0.92rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    margin-top: 0;
  }

  /* ===== Grid ===== */
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .resources-grid--single {
    grid-template-columns: 1fr;
    max-width: 640px;
  }

  /* ===== Resource Card ===== */
  .resource-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.25s ease, background 0.25s ease, box-shadow 0.3s ease, transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .resource-card:hover {
    border-color: var(--accent);
    background: var(--bg-card-hover);
    box-shadow: 0 12px 32px rgba(27, 58, 92, 0.1);
    transform: translateY(-4px);
  }

  .resource-card--featured {
    border-color: rgba(74, 144, 217, 0.25);
  }

  .resource-card--featured:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 24px rgba(74, 144, 217, 0.12);
  }

  .resource-card--internal {
    border-color: rgba(74, 144, 217, 0.2);
  }

  /* ===== Card Header ===== */
  .resource-card-header {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 0.875rem;
  }

  .resource-logo {
    width: 44px;
    height: 44px;
    border-radius: var(--radius);
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    color: var(--text-secondary);
    flex-shrink: 0;
  }

  .resource-logo--green {
    background: var(--accent-dim);
    border-color: rgba(74, 144, 217, 0.25);
    color: var(--accent);
  }

  .resource-logo--accent {
    background: var(--accent-dim);
    border-color: rgba(74, 144, 217, 0.2);
    color: var(--accent);
  }

  .resource-card-meta {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .resource-card-meta h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
    margin: 0;
  }

  /* ===== Tags ===== */
  .resource-tag {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 0.15rem 0.55rem;
    border-radius: 9999px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    color: var(--text-muted);
    width: fit-content;
  }

  .resource-tag--green {
    background: var(--accent-dim);
    border-color: rgba(74, 144, 217, 0.25);
    color: var(--accent);
  }

  .resource-tag--accent {
    background: var(--accent-dim);
    border-color: rgba(74, 144, 217, 0.2);
    color: var(--accent);
  }

  /* ===== Description ===== */
  .resource-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
    flex: 1;
    margin-bottom: 1.25rem;
  }

  /* ===== CTA Button ===== */
  .resource-cta-btn {
    display: inline-block;
    background: var(--accent);
    color: #FFFFFF;
    font-size: 0.875rem;
    font-weight: 700;
    padding: 0.65rem 1.25rem;
    border-radius: var(--radius);
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: var(--shadow-accent);
    width: fit-content;
    margin-top: auto;
  }

  .resource-cta-btn:hover {
    background: var(--accent-hover);
    color: #FFFFFF;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(74, 144, 217, 0.3);
  }

  .resource-cta-btn:active {
    transform: translateY(0) scale(0.98);
  }

  .resource-cta-btn--green {
    background: var(--accent);
    box-shadow: var(--shadow-accent);
  }

  .resource-cta-btn--green:hover {
    background: var(--accent-hover);
    color: #FFFFFF;
    box-shadow: 0 6px 20px rgba(74, 144, 217, 0.3);
  }

  /* ===== Disclaimer Section ===== */
  .resources-disclaimer-section {
    margin-top: 1rem;
  }

  .resources-disclaimer-box {
    background: #FFF8ED;
    border: 1px solid #F0DFC0;
    border-radius: var(--radius-lg);
    padding: 2rem 2rem;
  }

  .resources-disclaimer-box h2 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: #7A5B2E;
    margin-bottom: 0.875rem;
    margin-top: 0;
  }

  .resources-disclaimer-box p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .resources-disclaimer-box p:last-of-type {
    margin-bottom: 1.25rem;
  }

  .resources-disclaimer-box strong {
    color: var(--text-primary);
  }

  .resources-disclaimer-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: #7A5B2E;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .resources-disclaimer-link:hover {
    color: #78350F;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .resources-hero {
      padding: 2.5rem 1rem 2rem;
    }

    .resources-page {
      padding: 2rem 1rem 3rem;
    }

    .resources-grid {
      grid-template-columns: 1fr;
    }

    .resources-grid--single {
      max-width: 100%;
    }

    .resources-disclaimer-box {
      padding: 1.5rem 1.25rem;
    }

    .resource-cta-btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
