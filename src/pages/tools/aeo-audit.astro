---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Free AEO Audit Tool — Is Your Content AI-Ready?';
const description = 'Analyze your content for Answer Engine Optimization (AEO). Get a score for AI citation readiness across 7 dimensions — extraction, FAQ structure, schema, freshness, evidence, clarity, and overall grade.';

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is Answer Engine Optimization (AEO)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AEO is the practice of structuring content so AI systems like ChatGPT, Claude, and Google AI Overviews can accurately extract, cite, and surface your information. It focuses on quotable sentences, clear FAQ pairs, schema markup, and evidence-backed claims."
      }
    },
    {
      "@type": "Question",
      "name": "How does the 18-token extraction test work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 18-token test checks whether your sentences are self-contained and quotable within roughly 18 tokens (about 15-20 words). AI models prefer concise, complete statements they can extract without losing meaning."
      }
    },
    {
      "@type": "Question",
      "name": "Why does FAQ structure matter for AI visibility?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AI systems look for clear question-answer pairs when generating responses. FAQ answers between 30-50 words are the sweet spot for AI extraction. Pairing them with FAQPage JSON-LD schema increases the chance of being cited."
      }
    },
    {
      "@type": "Question",
      "name": "How often should I update content for AEO?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Research shows 95% of AI citations come from content updated within the last 10 months. Update key pages at least quarterly, add visible 'Last updated' dates, and refresh data points and statistics regularly."
      }
    },
    {
      "@type": "Question",
      "name": "What schema markup helps with AI citations?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "FAQPage schema is the most impactful for AEO. HowTo, Product, and Organization schemas also help. Use JSON-LD format in the page head and validate with Google's Rich Results Test before publishing."
      }
    }
  ]
});

const toolSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "AEO Audit Tool",
  "description": "Free tool to analyze content for Answer Engine Optimization readiness. Scores content across 7 AI citation dimensions.",
  "url": "https://passiveyieldlab.com/tools/aeo-audit",
  "applicationCategory": "SEO Tool",
  "operatingSystem": "Web Browser",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "creator": {
    "@type": "Organization",
    "name": "Passive Yield Lab",
    "url": "https://passiveyieldlab.com"
  },
  "dateModified": "2026-03-29"
});

const combinedSchema = `[${toolSchema},${faqSchema}]`;
---

<BaseLayout title={title} description={description} ogImage="/og/tools.svg" articleSchema={combinedSchema}>
  <div class="aeo-page">

    <!-- Hero -->
    <section class="aeo-hero">
      <span class="aeo-badge">Free Tool</span>
      <h1>AEO Content <span class="accent">Audit</span></h1>
      <p>Paste your content and get an instant AI citation readiness score. See exactly what to fix so ChatGPT, Claude, and Google AI Overviews quote <em>you</em>.</p>
      <small class="aeo-updated">Last updated: March 2026. Methodology based on GEO/AEO research.</small>
    </section>

    <!-- Input Section -->
    <section class="aeo-input-section">
      <div class="aeo-input-card">
        <div class="input-tabs">
          <button class="input-tab active" id="tab-text" type="button">Paste Text</button>
          <button class="input-tab" id="tab-url" type="button">Enter URL</button>
        </div>

        <div class="input-panel" id="panel-text">
          <label for="content-input" class="sr-only">Paste your article or page content</label>
          <textarea id="content-input" rows="10" placeholder="Paste your article, blog post, or page content here..."></textarea>
        </div>

        <div class="input-panel" id="panel-url" style="display:none">
          <label for="url-input" class="sr-only">Page URL to audit</label>
          <div class="url-input-row">
            <input type="url" id="url-input" placeholder="https://example.com/your-article" />
          </div>
          <p class="url-note">URL fetch may be blocked by CORS. For best results, paste your content directly.</p>
        </div>

        <button class="aeo-btn" id="audit-btn" type="button">Audit My Content</button>
      </div>
    </section>

    <!-- Results Section -->
    <section class="aeo-results" id="aeo-results" style="display:none" aria-live="polite">

      <!-- Overall Score -->
      <div class="score-hero" id="score-hero">
        <div class="score-ring-wrap">
          <svg class="score-ring" viewBox="0 0 120 120" aria-hidden="true">
            <circle cx="60" cy="60" r="52" class="score-ring-bg" />
            <circle cx="60" cy="60" r="52" class="score-ring-fill" id="score-ring-fill"
              stroke-dasharray="326.73" stroke-dashoffset="326.73" />
          </svg>
          <div class="score-number" id="score-number">0</div>
        </div>
        <div class="score-meta">
          <span class="score-grade" id="score-grade">—</span>
          <span class="score-label" id="score-label">Analyzing...</span>
        </div>
      </div>

      <!-- Category Breakdown -->
      <div class="category-grid" id="category-grid">
        <!-- Filled by JS -->
      </div>

      <!-- Detailed Findings -->
      <div class="findings-section" id="findings-section">
        <h2 class="findings-title">Detailed Findings</h2>
        <div id="findings-list">
          <!-- Filled by JS -->
        </div>
      </div>

      <!-- Generated Schema -->
      <div class="schema-section" id="schema-section" style="display:none">
        <h2 class="findings-title">Generated FAQ Schema</h2>
        <p class="schema-desc">Copy this JSON-LD and add it to your page's <code>&lt;head&gt;</code> to enable rich results.</p>
        <div class="schema-code-wrap">
          <button class="copy-btn" id="copy-schema-btn" type="button">Copy</button>
          <pre class="schema-code" id="schema-output"></pre>
        </div>
      </div>

      <!-- CTA -->
      <div class="aeo-cta">
        <h3>Want a deeper audit?</h3>
        <p>Join our newsletter for advanced AEO strategies, monthly content audits, and AI visibility tracking.</p>
        <a href="/" class="aeo-cta-btn">Explore Passive Yield Lab</a>
      </div>

    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="faq-inner">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>What is Answer Engine Optimization (AEO)?</h3>
          <p>AEO is the practice of structuring content so AI systems like ChatGPT, Claude, and Google AI Overviews can accurately extract, cite, and surface your information. It focuses on quotable sentences, clear FAQ pairs, schema markup, and evidence-backed claims.</p>
        </div>

        <div class="faq-item">
          <h3>How does the 18-token extraction test work?</h3>
          <p>The 18-token test checks whether your sentences are self-contained and quotable within roughly 18 tokens (about 15-20 words). AI models prefer concise, complete statements they can extract without losing meaning.</p>
        </div>

        <div class="faq-item">
          <h3>Why does FAQ structure matter for AI visibility?</h3>
          <p>AI systems look for clear question-answer pairs when generating responses. FAQ answers between 30-50 words are the sweet spot for AI extraction. Pairing them with FAQPage JSON-LD schema increases the chance of being cited.</p>
        </div>

        <div class="faq-item">
          <h3>How often should I update content for AEO?</h3>
          <p>Research shows 95% of AI citations come from content updated within the last 10 months. Update key pages at least quarterly, add visible "Last updated" dates, and refresh data points and statistics regularly.</p>
        </div>

        <div class="faq-item">
          <h3>What schema markup helps with AI citations?</h3>
          <p>FAQPage schema is the most impactful for AEO. HowTo, Product, and Organization schemas also help. Use JSON-LD format in the page head and validate with Google's Rich Results Test before publishing.</p>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
/* ===== Page Wrapper ===== */
.aeo-page {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 1.5rem 4rem;
}

/* ===== Hero ===== */
.aeo-hero {
  text-align: center;
  padding: 3.5rem 1rem 2.5rem;
}

.aeo-badge {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--accent);
  background: var(--accent-dim);
  border: 1px solid rgba(37,99,235,0.25);
  padding: 0.25rem 0.75rem;
  border-radius: 9999px;
  margin-bottom: 1rem;
}

.aeo-hero h1 {
  font-size: clamp(1.9rem, 4.5vw, 3rem);
  font-weight: 800;
  line-height: 1.15;
  margin-bottom: 0.9rem;
}

.aeo-hero .accent {
  color: var(--accent);
}

.aeo-hero p {
  font-size: 1.1rem;
  color: var(--text-secondary);
  max-width: 580px;
  margin: 0 auto;
}

.aeo-updated {
  display: block;
  margin-top: 0.75rem;
  font-size: 0.78rem;
  color: var(--text-muted);
}

/* ===== Input Section ===== */
.aeo-input-section {
  margin-bottom: 2.5rem;
}

.aeo-input-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.75rem;
}

.input-tabs {
  display: flex;
  gap: 0;
  margin-bottom: 1.25rem;
  border-bottom: 1px solid var(--border);
}

.input-tab {
  padding: 0.6rem 1.25rem;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text-muted);
  cursor: pointer;
  transition: color 0.2s, border-color 0.2s;
}

.input-tab.active {
  color: var(--accent);
  border-bottom-color: var(--accent);
}

.input-tab:hover:not(.active) {
  color: var(--text-secondary);
}

textarea {
  width: 100%;
  padding: 0.85rem 1rem;
  background: var(--bg-secondary);
  border: 1px solid var(--border-light);
  border-radius: var(--radius);
  color: var(--text-primary);
  font-size: 0.9rem;
  font-family: inherit;
  line-height: 1.6;
  resize: vertical;
  transition: border-color 0.2s;
}

textarea:focus {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
}

.url-input-row {
  display: flex;
  gap: 0.5rem;
}

.url-input-row input {
  flex: 1;
  padding: 0.65rem 0.9rem;
  background: var(--bg-secondary);
  border: 1px solid var(--border-light);
  border-radius: var(--radius);
  color: var(--text-primary);
  font-size: 0.9rem;
  transition: border-color 0.2s;
}

.url-input-row input:focus {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
}

.url-note {
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-top: 0.5rem;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border-width: 0;
}

.aeo-btn {
  width: 100%;
  padding: 0.85rem;
  background: var(--accent);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius);
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.2s, transform 0.1s;
  margin-top: 1rem;
}

.aeo-btn:hover {
  background: var(--accent-hover);
}

.aeo-btn:active {
  transform: scale(0.98);
}

.aeo-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

/* ===== Score Hero ===== */
.score-hero {
  display: flex;
  align-items: center;
  gap: 2rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 2rem;
  margin-bottom: 2rem;
}

.score-ring-wrap {
  position: relative;
  width: 120px;
  height: 120px;
  flex-shrink: 0;
}

.score-ring {
  width: 100%;
  height: 100%;
  transform: rotate(-90deg);
}

.score-ring-bg {
  fill: none;
  stroke: var(--border-light);
  stroke-width: 8;
}

.score-ring-fill {
  fill: none;
  stroke: var(--accent);
  stroke-width: 8;
  stroke-linecap: round;
  transition: stroke-dashoffset 1s ease, stroke 0.3s;
}

.score-number {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  font-weight: 800;
  color: var(--text-primary);
}

.score-meta {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.score-grade {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--accent);
}

.score-label {
  font-size: 0.95rem;
  color: var(--text-secondary);
  line-height: 1.5;
  max-width: 400px;
}

/* ===== Category Grid ===== */
.category-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 0.75rem;
  margin-bottom: 2.5rem;
}

.cat-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.15rem;
  transition: border-color 0.2s;
}

.cat-card.pass {
  border-left: 3px solid #22c55e;
}

.cat-card.warn {
  border-left: 3px solid #eab308;
}

.cat-card.fail {
  border-left: 3px solid #ef4444;
}

.cat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0.5rem;
}

.cat-name {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--text-primary);
}

.cat-score {
  font-size: 0.82rem;
  font-weight: 700;
  padding: 0.15rem 0.5rem;
  border-radius: 9999px;
}

.cat-score.pass {
  color: #16a34a;
  background: rgba(34,197,94,0.1);
}

.cat-score.warn {
  color: #ca8a04;
  background: rgba(234,179,8,0.1);
}

.cat-score.fail {
  color: #dc2626;
  background: rgba(239,68,68,0.1);
}

.cat-bar {
  height: 4px;
  background: var(--border-light);
  border-radius: 9999px;
  overflow: hidden;
  margin-bottom: 0.5rem;
}

.cat-bar-fill {
  height: 100%;
  border-radius: 9999px;
  transition: width 0.8s ease;
}

.cat-bar-fill.pass { background: #22c55e; }
.cat-bar-fill.warn { background: #eab308; }
.cat-bar-fill.fail { background: #ef4444; }

.cat-desc {
  font-size: 0.75rem;
  color: var(--text-muted);
  line-height: 1.45;
}

/* ===== Findings ===== */
.findings-section {
  margin-bottom: 2.5rem;
}

.findings-title {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 1.25rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
}

.finding-group {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 1rem;
  overflow: hidden;
}

.finding-header {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  padding: 1rem 1.25rem;
  cursor: pointer;
  user-select: none;
  transition: background 0.15s;
}

.finding-header:hover {
  background: var(--bg-secondary);
}

.finding-icon {
  font-size: 1.1rem;
  flex-shrink: 0;
  width: 1.5rem;
  text-align: center;
}

.finding-header-text {
  flex: 1;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text-primary);
}

.finding-toggle {
  font-size: 0.75rem;
  color: var(--text-muted);
  transition: transform 0.2s;
}

.finding-group.open .finding-toggle {
  transform: rotate(180deg);
}

.finding-body {
  display: none;
  padding: 0 1.25rem 1.25rem;
}

.finding-group.open .finding-body {
  display: block;
}

.finding-item {
  padding: 0.6rem 0;
  border-top: 1px solid var(--border-light);
  font-size: 0.85rem;
  color: var(--text-secondary);
  line-height: 1.55;
}

.finding-item:first-child {
  border-top: none;
}

.finding-item code {
  background: var(--bg-secondary);
  padding: 0.15rem 0.4rem;
  border-radius: 4px;
  font-size: 0.8rem;
}

.finding-fix {
  display: block;
  margin-top: 0.35rem;
  color: var(--accent);
  font-weight: 600;
  font-size: 0.8rem;
}

/* ===== Schema Output ===== */
.schema-section {
  margin-bottom: 2.5rem;
}

.schema-desc {
  font-size: 0.85rem;
  color: var(--text-secondary);
  margin-bottom: 1rem;
}

.schema-desc code {
  background: var(--bg-secondary);
  padding: 0.15rem 0.4rem;
  border-radius: 4px;
  font-size: 0.8rem;
}

.schema-code-wrap {
  position: relative;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}

.schema-code {
  padding: 1.25rem;
  font-size: 0.78rem;
  line-height: 1.55;
  overflow-x: auto;
  color: var(--text-primary);
  white-space: pre-wrap;
  word-break: break-all;
  margin: 0;
}

.copy-btn {
  position: absolute;
  top: 0.5rem;
  right: 0.5rem;
  padding: 0.35rem 0.75rem;
  font-size: 0.72rem;
  font-weight: 600;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  cursor: pointer;
  color: var(--text-secondary);
  transition: background 0.15s;
}

.copy-btn:hover {
  background: var(--accent-dim);
  color: var(--accent);
}

/* ===== CTA ===== */
.aeo-cta {
  text-align: center;
  background: linear-gradient(135deg, rgba(37,99,235,0.04), var(--bg-secondary));
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 2.5rem 2rem;
  margin-bottom: 3rem;
}

.aeo-cta h3 {
  font-size: 1.25rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

.aeo-cta p {
  color: var(--text-secondary);
  font-size: 0.92rem;
  margin-bottom: 1.25rem;
  max-width: 420px;
  margin-left: auto;
  margin-right: auto;
}

.aeo-cta-btn {
  display: inline-block;
  padding: 0.7rem 1.5rem;
  background: var(--accent);
  color: #fff;
  border-radius: var(--radius);
  font-weight: 700;
  font-size: 0.9rem;
  text-decoration: none;
  transition: background 0.2s;
}

.aeo-cta-btn:hover {
  background: var(--accent-hover);
}

/* ===== FAQ (reuse site pattern) ===== */
.faq-section {
  padding: 2rem 0 0;
}

.faq-inner {
  max-width: 720px;
  margin: 0 auto;
}

.faq-inner h2 {
  font-size: 1.4rem;
  font-weight: 800;
  text-align: center;
  margin-bottom: 2rem;
}

.faq-item {
  margin-bottom: 1.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--border-light);
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-item h3 {
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

.faq-item p {
  font-size: 0.92rem;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* ===== Responsive ===== */
@media (max-width: 768px) {
  .score-hero {
    flex-direction: column;
    text-align: center;
    gap: 1.25rem;
    padding: 1.5rem;
  }
  .score-meta {
    align-items: center;
  }
  .category-grid {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 480px) {
  .category-grid {
    grid-template-columns: 1fr;
  }
  .aeo-input-card {
    padding: 1.25rem;
  }
}
</style>

<script>
  // ===== Tab Switching =====
  const tabText = document.getElementById('tab-text');
  const tabUrl = document.getElementById('tab-url');
  const panelText = document.getElementById('panel-text');
  const panelUrl = document.getElementById('panel-url');

  tabText?.addEventListener('click', () => {
    tabText.classList.add('active');
    tabUrl?.classList.remove('active');
    if (panelText) panelText.style.display = '';
    if (panelUrl) panelUrl.style.display = 'none';
  });

  tabUrl?.addEventListener('click', () => {
    tabUrl.classList.add('active');
    tabText?.classList.remove('active');
    if (panelUrl) panelUrl.style.display = '';
    if (panelText) panelText.style.display = 'none';
  });

  // ===== Copy Schema =====
  document.getElementById('copy-schema-btn')?.addEventListener('click', () => {
    const code = document.getElementById('schema-output')?.textContent || '';
    navigator.clipboard.writeText(code).then(() => {
      const btn = document.getElementById('copy-schema-btn');
      if (btn) { btn.textContent = 'Copied!'; setTimeout(() => { btn.textContent = 'Copy'; }, 2000); }
    });
  });

  // ===== Audit Engine =====
  const auditBtn = document.getElementById('audit-btn');
  auditBtn?.addEventListener('click', runAudit);

  async function runAudit() {
    const btn = document.getElementById('audit-btn') as HTMLButtonElement;
    const isUrlMode = document.getElementById('tab-url')?.classList.contains('active');
    let content = '';

    if (isUrlMode) {
      const url = (document.getElementById('url-input') as HTMLInputElement)?.value.trim();
      if (!url) return;
      btn.disabled = true;
      btn.textContent = 'Fetching...';
      try {
        const res = await fetch(url);
        const html = await res.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        content = doc.body?.innerText || doc.body?.textContent || '';
      } catch {
        btn.disabled = false;
        btn.textContent = 'Audit My Content';
        alert('Could not fetch URL. Try pasting your content directly instead.');
        return;
      }
    } else {
      content = (document.getElementById('content-input') as HTMLTextAreaElement)?.value.trim();
    }

    if (!content || content.length < 50) {
      alert('Please provide at least a few sentences of content to audit.');
      btn.disabled = false;
      btn.textContent = 'Audit My Content';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Analyzing...';

    // Run analysis
    const results = analyzeContent(content);
    renderResults(results);

    btn.disabled = false;
    btn.textContent = 'Audit My Content';
  }

  // ===== Analysis Functions =====

  interface CategoryResult {
    name: string;
    score: number;
    maxScore: number;
    findings: Finding[];
    summary: string;
  }

  interface Finding {
    type: 'pass' | 'warn' | 'fail';
    text: string;
    fix?: string;
    example?: string;
  }

  interface AuditResult {
    overallScore: number;
    grade: string;
    label: string;
    categories: CategoryResult[];
    faqPairs: { q: string; a: string }[];
  }

  function tokenCount(text: string): number {
    return text.split(/\s+/).filter(Boolean).length;
  }

  function getSentences(text: string): string[] {
    return text
      .replace(/\n{2,}/g, '. ')
      .split(/(?<=[.!?])\s+/)
      .map(s => s.trim())
      .filter(s => s.length > 10);
  }

  function analyzeContent(content: string): AuditResult {
    const sentences = getSentences(content);
    const totalSentences = sentences.length;
    const words = content.split(/\s+/).filter(Boolean);
    const totalWords = words.length;
    const lines = content.split('\n');

    // 1. 18-Token Extraction Test
    const extractable = sentences.filter(s => {
      const wc = tokenCount(s);
      return wc >= 8 && wc <= 25 && !s.match(/\b(it|this|that|these|those|they)\b/i && !s.match(/^(however|but|also|and|or|yet)/i));
    });
    const extractionRatio = totalSentences > 0 ? extractable.length / totalSentences : 0;
    const extractionScore = Math.min(100, Math.round(extractionRatio * 130));
    const extractionFindings: Finding[] = [];

    if (extractionRatio >= 0.4) {
      extractionFindings.push({ type: 'pass', text: `${extractable.length} of ${totalSentences} sentences are self-contained and quotable (${Math.round(extractionRatio * 100)}%).` });
    } else if (extractionRatio >= 0.2) {
      extractionFindings.push({ type: 'warn', text: `Only ${extractable.length} of ${totalSentences} sentences pass the extraction test (${Math.round(extractionRatio * 100)}%). Aim for 40%+.`, fix: 'Break long sentences into standalone statements. Remove pronouns like "it" or "this" and use the actual subject.' });
    } else {
      extractionFindings.push({ type: 'fail', text: `Very few sentences are extractable (${extractable.length}/${totalSentences}). AI systems will struggle to quote this content.`, fix: 'Rewrite key claims as 15-20 word standalone sentences. Each should make sense without reading the paragraph around it.' });
    }

    const longSentences = sentences.filter(s => tokenCount(s) > 35);
    if (longSentences.length > 0) {
      extractionFindings.push({ type: 'warn', text: `${longSentences.length} sentences exceed 35 words. These are too long for AI extraction.`, fix: 'Split into two shorter sentences. Front-load the key fact.' });
    }

    // 2. FAQ Structure
    const questionPatterns = /^(?:#{1,3}\s*)?(?:what|how|why|when|where|which|who|is|are|can|do|does|should|will|could|would)[^.]*\?/im;
    const questionLines = lines.filter(l => questionPatterns.test(l.trim()));
    const hasQAPairs = questionLines.length;

    let faqScore = 0;
    const faqFindings: Finding[] = [];
    const detectedFaqs: { q: string; a: string }[] = [];

    if (hasQAPairs >= 5) {
      faqScore = 90;
      faqFindings.push({ type: 'pass', text: `Found ${hasQAPairs} question-answer patterns. Strong FAQ structure.` });
    } else if (hasQAPairs >= 2) {
      faqScore = 55;
      faqFindings.push({ type: 'warn', text: `Found ${hasQAPairs} Q&A patterns. Aim for at least 5 FAQ pairs for optimal AI extraction.`, fix: 'Add more natural questions as H2/H3 headings with 30-50 word answers directly below.' });
    } else {
      faqScore = 15;
      faqFindings.push({ type: 'fail', text: 'No clear FAQ structure detected. AI systems look for question-answer pairs.', fix: 'Add an FAQ section with 5-15 questions as headings. Keep answers between 30-50 words.' });
    }

    // Extract Q&A pairs for schema generation
    for (let i = 0; i < lines.length; i++) {
      if (questionPatterns.test(lines[i].trim())) {
        const q = lines[i].replace(/^#{1,3}\s*/, '').trim();
        let a = '';
        for (let j = i + 1; j < lines.length && j <= i + 5; j++) {
          const line = lines[j].trim();
          if (!line) continue;
          if (questionPatterns.test(line) || /^#{1,3}\s/.test(line)) break;
          a += (a ? ' ' : '') + line;
          if (tokenCount(a) >= 30) break;
        }
        if (a && tokenCount(a) >= 10) {
          detectedFaqs.push({ q, a: a.slice(0, 300) });
        }
      }
    }

    // Check FAQ answer length
    if (detectedFaqs.length > 0) {
      const shortAnswers = detectedFaqs.filter(f => tokenCount(f.a) < 15);
      const longAnswers = detectedFaqs.filter(f => tokenCount(f.a) > 60);
      if (shortAnswers.length > 0) {
        faqFindings.push({ type: 'warn', text: `${shortAnswers.length} FAQ answers are too short (under 15 words). Sweet spot is 30-50 words.` });
      }
      if (longAnswers.length > 0) {
        faqFindings.push({ type: 'warn', text: `${longAnswers.length} FAQ answers exceed 60 words. Trim to 30-50 words for AI extraction.` });
      }
    }

    // 3. Schema Markup (check for JSON-LD patterns in content)
    const hasSchemaRef = /json-ld|schema\.org|FAQPage|HowTo|structured data/i.test(content);
    let schemaScore = 0;
    const schemaFindings: Finding[] = [];

    if (hasSchemaRef) {
      schemaScore = 70;
      schemaFindings.push({ type: 'pass', text: 'Content references structured data or schema markup.' });
    } else {
      schemaScore = 10;
      schemaFindings.push({ type: 'fail', text: 'No schema markup references detected in the content.', fix: 'Add FAQPage JSON-LD schema to your page. This tool generates it for you below.' });
    }

    // For text analysis, we generate suggested schema regardless
    if (detectedFaqs.length >= 2) {
      schemaScore = Math.max(schemaScore, 40);
      schemaFindings.push({ type: 'warn', text: `We detected ${detectedFaqs.length} FAQ pairs and generated a FAQPage schema for you below.` });
    }

    // 4. Freshness Signals
    const datePatterns = /(?:january|february|march|april|may|june|july|august|september|october|november|december)\s+\d{4}|(?:q[1-4]\s+\d{4})|\d{4}-\d{2}-\d{2}|(?:as of|updated|last (?:updated|reviewed|modified))\s/i;
    const hasDates = datePatterns.test(content);
    const dateMatches = content.match(new RegExp(datePatterns.source, 'gi')) || [];
    let freshnessScore = 0;
    const freshnessFindings: Finding[] = [];

    if (dateMatches.length >= 3) {
      freshnessScore = 90;
      freshnessFindings.push({ type: 'pass', text: `Found ${dateMatches.length} date/freshness signals. Content appears well-dated.` });
    } else if (hasDates) {
      freshnessScore = 50;
      freshnessFindings.push({ type: 'warn', text: `Only ${dateMatches.length} date reference(s) found. Add "Last updated" and date-stamp data points.`, fix: 'Add "Last updated: [Month Year]" at the top. Date-stamp all statistics and APY figures.' });
    } else {
      freshnessScore = 10;
      freshnessFindings.push({ type: 'fail', text: 'No freshness signals detected. 95% of AI citations come from content updated in the last 10 months.', fix: 'Add "Last updated: [date]" prominently. Include "as of [date]" next to every statistic or claim.' });
    }

    // 5. Evidence Quality
    const statPatterns = /\d+(?:\.\d+)?%|\$[\d,]+(?:\.\d+)?|\d+(?:,\d{3})+/g;
    const stats = content.match(statPatterns) || [];
    const sourcePatterns = /(?:according to|source:|study|research|report|data from|survey|analysis by)/gi;
    const sources = content.match(sourcePatterns) || [];
    let evidenceScore = 0;
    const evidenceFindings: Finding[] = [];

    const statDensity = totalWords > 0 ? (stats.length / totalWords) * 1000 : 0;
    if (stats.length >= 5 && sources.length >= 2) {
      evidenceScore = 85;
      evidenceFindings.push({ type: 'pass', text: `Found ${stats.length} statistics and ${sources.length} source references. Strong evidence base.` });
    } else if (stats.length >= 2) {
      evidenceScore = 50;
      evidenceFindings.push({ type: 'warn', text: `Found ${stats.length} statistics but ${sources.length} source attribution(s). AI systems prefer cited evidence.`, fix: 'Add "according to [source]" or "source: [name]" next to claims. Include methodology when possible.' });
    } else {
      evidenceScore = 15;
      evidenceFindings.push({ type: 'fail', text: 'Very few statistics or source citations found. Unsupported claims hurt AI credibility.', fix: 'Add specific numbers, percentages, and dollar figures. Cite sources with dates and methodology.' });
    }

    // 6. Pronoun Clarity
    const vaguePronouns = sentences.filter(s => {
      const first20 = s.split(/\s+/).slice(0, 5).join(' ');
      return /^(it|this|that|these|those|they)\s/i.test(first20);
    });
    let pronounScore = 0;
    const pronounFindings: Finding[] = [];
    const pronounRatio = totalSentences > 0 ? vaguePronouns.length / totalSentences : 0;

    if (pronounRatio <= 0.05) {
      pronounScore = 95;
      pronounFindings.push({ type: 'pass', text: 'Minimal vague pronouns. Subjects are clear throughout.' });
    } else if (pronounRatio <= 0.15) {
      pronounScore = 60;
      pronounFindings.push({ type: 'warn', text: `${vaguePronouns.length} sentences start with vague pronouns (it, this, that, they).`, fix: 'Replace leading pronouns with the actual subject. "This is useful" becomes "Staking ETH is useful."' });
    } else {
      pronounScore = 25;
      pronounFindings.push({ type: 'fail', text: `${vaguePronouns.length} of ${totalSentences} sentences start with vague pronouns. AI cannot extract these cleanly.`, fix: 'Every sentence should name its subject explicitly. Replace "It" with the specific noun.' });
    }

    if (vaguePronouns.length > 0 && vaguePronouns.length <= 5) {
      vaguePronouns.forEach(s => {
        const short = s.length > 80 ? s.slice(0, 80) + '...' : s;
        pronounFindings.push({ type: 'warn', text: `Example: "${short}"` });
      });
    }

    // 7. Overall AEO Score
    const categories: CategoryResult[] = [
      { name: '18-Token Extraction', score: extractionScore, maxScore: 100, findings: extractionFindings, summary: 'Self-contained, quotable sentences' },
      { name: 'FAQ Structure', score: faqScore, maxScore: 100, findings: faqFindings, summary: 'Clear Q&A pairs for AI extraction' },
      { name: 'Schema Markup', score: schemaScore, maxScore: 100, findings: schemaFindings, summary: 'Structured data for rich results' },
      { name: 'Freshness Signals', score: freshnessScore, maxScore: 100, findings: freshnessFindings, summary: 'Dates, update timestamps, recency' },
      { name: 'Evidence Quality', score: evidenceScore, maxScore: 100, findings: evidenceFindings, summary: 'Statistics, sources, methodology' },
      { name: 'Pronoun Clarity', score: pronounScore, maxScore: 100, findings: pronounFindings, summary: 'Clear subjects, no vague "it/this"' },
    ];

    const rawTotal = categories.reduce((sum, c) => sum + c.score, 0);
    const overallScore = Math.round(rawTotal / categories.length);

    let grade: string;
    let label: string;
    if (overallScore >= 85) { grade = 'A'; label = 'Excellent AEO readiness. Your content is well-positioned for AI citations.'; }
    else if (overallScore >= 70) { grade = 'B'; label = 'Good foundation. A few improvements will significantly boost AI visibility.'; }
    else if (overallScore >= 50) { grade = 'C'; label = 'Needs work. Several areas need attention before AI systems will reliably cite this content.'; }
    else if (overallScore >= 30) { grade = 'D'; label = 'Poor AEO readiness. Major structural changes needed for AI citation eligibility.'; }
    else { grade = 'F'; label = 'Not AI-ready. This content needs a full AEO rewrite to be visible to answer engines.'; }

    return { overallScore, grade, label, categories, faqPairs: detectedFaqs };
  }

  // ===== Render Results =====
  function renderResults(results: AuditResult) {
    const resultsEl = document.getElementById('aeo-results');
    if (resultsEl) resultsEl.style.display = '';

    // Animate score ring
    const circumference = 326.73;
    const offset = circumference - (results.overallScore / 100) * circumference;
    const ringFill = document.getElementById('score-ring-fill');
    if (ringFill) {
      const color = results.overallScore >= 70 ? '#22c55e' : results.overallScore >= 50 ? '#eab308' : '#ef4444';
      ringFill.style.stroke = color;
      requestAnimationFrame(() => {
        ringFill.style.strokeDashoffset = String(offset);
      });
    }

    // Animate score number
    const scoreNum = document.getElementById('score-number');
    if (scoreNum) animateNumber(scoreNum, 0, results.overallScore, 800);

    const gradeEl = document.getElementById('score-grade');
    if (gradeEl) {
      gradeEl.textContent = `Grade: ${results.grade}`;
      const color = results.overallScore >= 70 ? '#22c55e' : results.overallScore >= 50 ? '#eab308' : '#ef4444';
      gradeEl.style.color = color;
    }

    const labelEl = document.getElementById('score-label');
    if (labelEl) labelEl.textContent = results.label;

    // Category cards
    const grid = document.getElementById('category-grid');
    if (grid) {
      grid.innerHTML = results.categories.map(cat => {
        const level = cat.score >= 70 ? 'pass' : cat.score >= 40 ? 'warn' : 'fail';
        return `
          <div class="cat-card ${level}">
            <div class="cat-header">
              <span class="cat-name">${cat.name}</span>
              <span class="cat-score ${level}">${cat.score}/100</span>
            </div>
            <div class="cat-bar"><div class="cat-bar-fill ${level}" style="width:${cat.score}%"></div></div>
            <div class="cat-desc">${cat.summary}</div>
          </div>
        `;
      }).join('');
    }

    // Findings accordion
    const findingsEl = document.getElementById('findings-list');
    if (findingsEl) {
      findingsEl.innerHTML = results.categories.map(cat => {
        const iconMap = { pass: '<span style="color:#22c55e">&#10003;</span>', warn: '<span style="color:#eab308">&#9888;</span>', fail: '<span style="color:#ef4444">&#10007;</span>' };
        const worstType = cat.findings.some(f => f.type === 'fail') ? 'fail' : cat.findings.some(f => f.type === 'warn') ? 'warn' : 'pass';
        const icon = iconMap[worstType];

        const items = cat.findings.map(f => {
          let html = `<div class="finding-item">${f.text}`;
          if (f.fix) html += `<span class="finding-fix">Fix: ${f.fix}</span>`;
          html += `</div>`;
          return html;
        }).join('');

        return `
          <div class="finding-group">
            <div class="finding-header" onclick="this.parentElement.classList.toggle('open')">
              <span class="finding-icon">${icon}</span>
              <span class="finding-header-text">${cat.name} (${cat.score}/100)</span>
              <span class="finding-toggle">&#9660;</span>
            </div>
            <div class="finding-body">${items}</div>
          </div>
        `;
      }).join('');
    }

    // Generate FAQ schema if pairs found
    if (results.faqPairs.length >= 2) {
      const schemaSection = document.getElementById('schema-section');
      if (schemaSection) schemaSection.style.display = '';

      const schema = {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": results.faqPairs.map(f => ({
          "@type": "Question",
          "name": f.q,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": f.a
          }
        }))
      };

      const output = document.getElementById('schema-output');
      if (output) output.textContent = JSON.stringify(schema, null, 2);
    } else {
      const schemaSection = document.getElementById('schema-section');
      if (schemaSection) schemaSection.style.display = 'none';
    }

    // Scroll to results
    resultsEl?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function animateNumber(el: HTMLElement, start: number, end: number, duration: number) {
    const startTime = performance.now();
    function update(now: number) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = String(Math.round(start + (end - start) * eased));
      if (progress < 1) requestAnimationFrame(update);
    }
    requestAnimationFrame(update);
  }
</script>
