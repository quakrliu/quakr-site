</style>

<script>
// ── Data ──────────────────────────────────────────────────────────────
const COIN_DATA = {
  ETH:  { apy: 3.8,  price: 3200 },
  SOL:  { apy: 7.0,  price: 180  },
  ADA:  { apy: 4.0,  price: 0.52 },
  DOT:  { apy: 14.0, price: 8.5  },
  AVAX: { apy: 8.5,  price: 38   },
  ATOM: { apy: 18.0, price: 11   },
  NEAR: { apy: 9.0,  price: 6.2  },
  MATIC:{ apy: 5.0,  price: 0.85 },
};

// ── Helpers ───────────────────────────────────────────────────────────
function formatUSD(n) {
  if (n >= 1_000_000) return '$' + (n / 1_000_000).toFixed(2) + 'M';
  if (n >= 1_000)     return '$' + n.toLocaleString('en-US', { maximumFractionDigits: 0 });
  return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function formatTokens(n, coin) {
  const decimals = n < 0.001 ? 6 : n < 1 ? 4 : 2;
  return n.toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals }) + ' ' + coin;
}

function calcRewards(principal, apyPct, years, compoundFreq) {
  const r = apyPct / 100;
  if (compoundFreq === 0) {
    return principal * (1 + r * years);
  }
  return principal * Math.pow(1 + r / compoundFreq, compoundFreq * years);
}

// Animate a number from 0 to target in ~600ms
function animateNumber(el, targetText) {
  el.style.opacity = '0';
  el.style.transform = 'translateY(6px)';
  requestAnimationFrame(() => {
    el.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
    el.style.opacity = '1';
    el.style.transform = 'translateY(0)';
    el.textContent = targetText;
  });
}

// ── Main calculate function ────────────────────────────────────────────
function calculate() {
  const coinSelect   = document.getElementById('coin-select');
  const amountInput  = document.getElementById('amount-input');
  const priceInput   = document.getElementById('price-input');
  const apyInput     = document.getElementById('apy-input');
  const compSelect   = document.getElementById('compound-select');

  const coin     = coinSelect.value;
  const amount   = parseFloat(amountInput.value) || 0;
  const price    = parseFloat(priceInput.value)  || 0;
  const apy      = parseFloat(apyInput.value)    || 0;
  const freq     = parseInt(compSelect.value)    || 0;

  if (amount <= 0 || price <= 0 || apy <= 0) {
    alert('Please enter valid positive values for holdings, price, and APY.');
    return;
  }

  const years = [1, 3, 5];
  const results = years.map(y => {
    const totalTokens   = calcRewards(amount, apy, y, freq);
    const earnedTokens  = totalTokens - amount;
    const totalUSD      = totalTokens * price;
    const earnedUSD     = earnedTokens * price;
    const gainPct       = (earnedTokens / amount * 100).toFixed(1);
    return { totalTokens, earnedTokens, totalUSD, earnedUSD, gainPct };
  });

  // Show results panel
  document.getElementById('results-placeholder').style.display = 'none';
  const content = document.getElementById('results-content');
  content.style.display = 'block';

  // Re-trigger animations by cloning the cards container
  const cards = content.querySelectorAll('.result-card');
  cards.forEach(c => { c.style.animation = 'none'; void c.offsetWidth; c.style.animation = ''; });

  // Fill result cards
  [1, 3, 5].forEach((y, i) => {
    const r = results[i];
    animateNumber(document.getElementById(`tokens-${y}`), formatTokens(r.earnedTokens, coin));
    animateNumber(document.getElementById(`usd-${y}`),    formatUSD(r.totalUSD));
    animateNumber(document.getElementById(`gain-${y}`),   '+' + r.gainPct + '% total');
  });

  // Bar chart — scale relative to 5yr max
  const max = results[2].totalUSD;
  [1, 3, 5].forEach((y, i) => {
    const pct = max > 0 ? (results[i].totalUSD / max * 100) : 0;
    const bar = document.getElementById(`bar-${y}`);
    bar.style.width = '0%';
    requestAnimationFrame(() => {
      bar.style.transition = 'width 0.9s cubic-bezier(0.4, 0, 0.2, 1)';
      bar.style.width = pct + '%';
    });
    document.getElementById(`bar-val-${y}`).textContent = formatUSD(results[i].totalUSD);
  });

  // Loss aversion / scarcity — "if you wait 1 year"
  const missedY1 = results[0].earnedUSD;
  document.getElementById('loss-amount').textContent = formatUSD(missedY1);

  // Opportunity cost table
  [1, 3, 5].forEach((y, i) => {
    document.getElementById(`opp-stake-${y}`).textContent = '+' + formatUSD(results[i].earnedUSD);
    document.getElementById(`opp-miss-${y}`).textContent  = '-' + formatUSD(results[i].earnedUSD);
  });

  // Show CTA
  document.getElementById('staking-cta').style.display = 'block';

  // Scroll to results on mobile
  if (window.innerWidth < 800) {
    document.getElementById('calc-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}

// ── Wire up coin selector → update price + APY preset ─────────────────
document.getElementById('coin-select').addEventListener('change', function() {
  const data = COIN_DATA[this.value];
  if (!data) return;
  document.getElementById('price-input').value   = data.price;
  document.getElementById('apy-input').value     = data.apy;
  document.getElementById('apy-slider').value    = data.apy;
  document.getElementById('apy-badge').textContent = 'Preset: ' + data.apy + '%';
});

// ── Sync slider ↔ number input ────────────────────────────────────────
document.getElementById('apy-slider').addEventListener('input', function() {
  document.getElementById('apy-input').value = this.value;
  document.getElementById('apy-badge').textContent = 'Custom: ' + this.value + '%';
});

document.getElementById('apy-input').addEventListener('input', function() {
  const v = Math.min(Math.max(parseFloat(this.value) || 0.1, 0.1), 50);
  document.getElementById('apy-slider').value = v;
  document.getElementById('apy-badge').textContent = 'Custom: ' + v + '%';
});

// ── Calculate button ──────────────────────────────────────────────────
document.getElementById('calc-btn').addEventListener('click', calculate);

// Also calculate on Enter key in any input
document.querySelectorAll('input[type="number"]').forEach(el => {
  el.addEventListener('keydown', e => { if (e.key === 'Enter') calculate(); });
});
</script>
