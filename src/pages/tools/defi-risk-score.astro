    },
    yearn: {
      name: 'Yearn Finance',
      category: 'Yield Aggregator',
      chains: 'Ethereum, Arbitrum, Polygon',
      tvl: '$0.5B',
      launched: '2020',
      scores: { tvl: 5, audit: 7, time: 7, gov: 6, sc: 6 },
      summary: 'Yearn pioneered automated yield optimization. TVL has declined from its $6B peak. Strategy complexity introduces unique risks, but the team has a strong security track record.',
      strengths: ['Pioneer of automated yield strategies', 'Strong security culture with bug bounties', 'Open-source strategies reviewed by community', 'Battle-tested core vault contracts'],
      risks: ['TVL significantly below peak ($6B → $0.5B)', 'Strategy complexity across many protocols', 'Dependent on underlying protocol safety', 'Declining competitive advantage vs newer vaults', 'Historical exploits in early strategies (2021)']
    }
  };

  const select = document.getElementById('protocol-select');

  function getRiskLevel(score) {
    if (score >= 9) return { label: 'Very Low Risk', color: '#22c55e', bg: 'rgba(34,197,94,0.12)' };
    if (score >= 7) return { label: 'Low Risk', color: '#3b82f6', bg: 'rgba(59,130,246,0.12)' };
    if (score >= 4) return { label: 'Moderate Risk', color: '#eab308', bg: 'rgba(234,179,8,0.12)' };
    return { label: 'High Risk', color: '#ef4444', bg: 'rgba(239,68,68,0.12)' };
  }

  function getBarColor(score) {
    if (score >= 9) return '#22c55e';
    if (score >= 7) return '#3b82f6';
    if (score >= 4) return '#eab308';
    return '#ef4444';
  }

  function updateDisplay(key) {
    const p = PROTOCOLS[key];
    const scores = p.scores;
    const avg = (scores.tvl + scores.audit + scores.time + scores.gov + scores.sc) / 5;
    const overall = Math.round(avg * 10) / 10;
    const rl = getRiskLevel(overall);

    // Meta
    document.getElementById('meta-category').textContent = p.category;
    document.getElementById('meta-chains').textContent = p.chains;
    document.getElementById('meta-tvl').textContent = p.tvl;
    document.getElementById('meta-launched').textContent = p.launched;

    // Score ring
    const pct = (overall / 10) * 100;
    const ringEl = document.getElementById('score-ring');
    ringEl.style.background = `conic-gradient(${rl.color} ${pct}%, var(--bg-secondary) ${pct}%)`;
    document.getElementById('score-number').textContent = overall.toFixed(1);

    // Name + badge
    document.getElementById('protocol-name').textContent = p.name;
    const badge = document.getElementById('risk-level-badge');
    badge.textContent = rl.label;
    badge.style.color = rl.color;
    badge.style.background = rl.bg;

    document.getElementById('protocol-summary').textContent = p.summary;

    // Breakdown bars
    const categories = [
      { key: 'tvl', barId: 'bar-tvl', scoreId: 'score-tvl' },
      { key: 'audit', barId: 'bar-audit', scoreId: 'score-audit' },
      { key: 'time', barId: 'bar-time', scoreId: 'score-time' },
      { key: 'gov', barId: 'bar-gov', scoreId: 'score-gov' },
      { key: 'sc', barId: 'bar-sc', scoreId: 'score-sc' }
    ];

    categories.forEach(({ key, barId, scoreId }) => {
      const s = scores[key];
      const bar = document.getElementById(barId);
      bar.style.width = (s * 10) + '%';
      bar.style.background = getBarColor(s);
      document.getElementById(scoreId).textContent = s + '/10';
    });

    // Strengths & risks
    const notesEl = document.getElementById('risk-notes');
    notesEl.style.display = 'grid';

    const sl = document.getElementById('strengths-list');
    const rl2 = document.getElementById('risks-list');
    sl.innerHTML = p.strengths.map(s => `<li>${s}</li>`).join('');
    rl2.innerHTML = p.risks.map(r => `<li>${r}</li>`).join('');
  }

  function buildOverviewTable() {
    const tbody = document.getElementById('overview-tbody');
    const rows = Object.entries(PROTOCOLS).map(([key, p]) => {
      const scores = p.scores;
      const avg = (scores.tvl + scores.audit + scores.time + scores.gov + scores.sc) / 5;
      const overall = Math.round(avg * 10) / 10;
      const rl = getRiskLevel(overall);
      return { key, p, overall, rl };
    }).sort((a, b) => b.overall - a.overall);

    tbody.innerHTML = rows.map(({ key, p, overall, rl }) => `
      <tr>
        <td><strong>${p.name}</strong></td>
        <td style="color:var(--text-muted);font-size:0.82rem">${p.category}</td>
        <td><span class="score-pill" style="color:${rl.color};background:${rl.bg}">${overall.toFixed(1)}</span></td>
        <td><span style="font-size:0.8rem;font-weight:600;color:${rl.color}">${rl.label}</span></td>
        <td><button class="view-btn" data-key="${key}">View</button></td>
      </tr>
    `).join('');

    tbody.querySelectorAll('.view-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const key = btn.getAttribute('data-key');
        select.value = key;
        updateDisplay(key);
        document.querySelector('.risk-wrapper').scrollIntoView({ behavior: 'smooth' });
      });
    });
  }

  select.addEventListener('change', () => updateDisplay(select.value));

  // Init
  updateDisplay('aave');
  buildOverviewTable();
});
</script>
