---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const categoryLabels: Record<string, string> = {
  staking: 'Staking',
  defi: 'DeFi',
  'exchange-reviews': 'Exchange Reviews',
  guides: 'Guides',
  'market-analysis': 'Market Analysis',
  tools: 'Tools',
  news: 'News',
};

export function getStaticPaths() {
  const cats = ['staking', 'defi', 'exchange-reviews', 'guides', 'market-analysis', 'tools', 'news'];
  return cats.map((cat) => ({
    params: { category: cat },
  }));
}

const { category } = Astro.params;
const label = categoryLabels[category!] || category;

const allPosts = await getCollection(
  'blog',
  ({ data }) => !data.draft && data.category === category
);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title={`${label} — Crypto Yield Guide`}
  description={`Browse all ${label} articles on Crypto Yield Guide.`}
  category={category}
>
  <div class="page-content">
    <h1>{label}</h1>
  </div>

  {posts.length === 0 ? (
    <div class="page-content">
      <p>No articles in this category yet. Check back soon!</p>
    </div>
  ) : (
    <section class="article-grid">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="article-card">
          <span class="card-category">{post.data.category}</span>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          <div class="card-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </div>
        </a>
      ))}
    </section>
  )}
</BaseLayout>
