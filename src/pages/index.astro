<script>
  // === Daily Pulse: Client-side hydration ===

  // 1. Today's Best APY (DeFiLlama)
  (async function loadTopYields() {
    const list = document.getElementById('dp-apy-list');
    const disclaimer = document.getElementById('dp-apy-disclaimer');
    if (!list) return;

    try {
      const res = await fetch('https://yields.llama.fi/pools');
      if (!res.ok) throw new Error('API error');
      const { data } = await res.json();

      // Filter: stablecoin or major token pools, TVL > $1M, from reputable protocols
      const reputable = ['aave-v3', 'lido', 'compound-v3', 'maker', 'jito', 'marinade-finance', 'rocket-pool', 'spark', 'ethena', 'morpho', 'pendle', 'jupiter', 'raydium'];
      const filtered = data
        .filter((p) => p.tvlUsd > 1_000_000 && p.apy > 0.5 && p.apy < 50 && reputable.some((r) => p.project.toLowerCase().includes(r)))
        .sort((a, b) => b.apy - a.apy)
        .slice(0, 3);

      if (filtered.length === 0) throw new Error('No qualifying pools');

      list.innerHTML = filtered
        .map(
          (p) => `
        <div class="dp-apy-row">
          <div class="dp-apy-info">
            <span class="dp-apy-protocol">${p.project}</span>
            <span class="dp-apy-pool">${p.symbol} · ${p.chain}</span>
          </div>
          <span class="dp-apy-value">${p.apy.toFixed(2)}%</span>
        </div>`
        )
        .join('');

      if (disclaimer) disclaimer.style.display = 'block';
    } catch {
      list.innerHTML = `<p class="dp-apy-error">Could not load live yields. <a href="/tools/yield-dashboard">Check the dashboard</a> instead.</p>`;
    }
  })();

  // 2. Daily Yield Tip
