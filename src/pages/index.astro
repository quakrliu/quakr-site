---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 12);

const categories = [
  { slug: 'staking', label: 'Staking' },
  { slug: 'defi', label: 'DeFi' },
  { slug: 'exchange-reviews', label: 'Exchange Reviews' },
  { slug: 'guides', label: 'Guides' },
  { slug: 'market-analysis', label: 'Market Analysis' },
  { slug: 'tools', label: 'Tools' },
  { slug: 'news', label: 'News' },
];
---

<BaseLayout title="Quakr">
  <section class="hero">
    <h1>
      <span class="accent">Earn More</span> From Your Crypto
    </h1>
    <p>
      Practical guides on staking, DeFi yield, exchange lending, and every other
      way to put your crypto to work — written by holders, for holders.
    </p>
    <a href="/blog" class="hero-cta">Read the Guides</a>
  </section>

  <div class="category-filter">
    <a href="/blog" class="active">All</a>
    {categories.map((cat) => (
      <a href={`/category/${cat.slug}`}>{cat.label}</a>
    ))}
  </div>

  <section class="article-grid">
    {posts.map((post) => (
      <a href={`/blog/${post.id}`} class="article-card">
        <span class="card-category">{post.data.category}</span>
        <h3>{post.data.title}</h3>
        <p>{post.data.description}</p>
        <div class="card-meta">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })}
          </time>
        </div>
      </a>
    ))}
  </section>

  <section class="email-signup">
    <div class="email-signup-box">
      <h2>Stay in the Loop</h2>
      <p>Get weekly crypto passive income tips straight to your inbox.</p>
      <form
        action="https://app.beehiiv.com/forms/YOUR_FORM_ID"
        method="POST"
        target="_blank"
      >
        <input
          type="email"
          name="email"
          placeholder="you@example.com"
          required
        />
        <button type="submit">Subscribe</button>
      </form>
    </div>
  </section>
</BaseLayout>
