    const tips = [
      "Staking ETH via Lido gives you stETH, which you can use in DeFi while still earning staking rewards. Double-dip your yield.",
      "Dollar-cost averaging into staking positions smooths out APY volatility. Don't chase the highest rate — chase consistency.",
      "Always check a protocol's TVL trend before depositing. Rising TVL + stable APY = healthy protocol. Falling TVL + rising APY = red flag.",
      "Diversify across at least 3 protocols and 2 chains. One exploit shouldn't wipe out your entire passive income.",
      "Restaking (EigenLayer, Symbiotic) can boost rewards 2-3x, but adds smart contract risk layers. Size positions accordingly.",
      "Stablecoin yields (USDC/USDT lending) are the 'savings account' of DeFi. Currently 4-8% on Aave/Compound. Lower risk, steady income.",
      "Gas fees eat into yields on small positions. On Ethereum, aim for at least $5,000 per position. For smaller amounts, use Solana or L2s.",
      "Auto-compounding vaults (like Yearn or Beefy) reinvest rewards automatically. The compounding effect adds 15-30% more yield annually.",
      "Check your staking rewards tax obligations. In many jurisdictions, staking rewards are taxable as income when received.",
      "The best yield strategy is the one you understand. If you can't explain how a protocol generates its APY, don't deposit there.",
      "Liquid staking tokens (stETH, mSOL, jitoSOL) let you exit positions faster than traditional staking lockups. Liquidity matters.",
      "Set a calendar reminder to review your positions monthly. APYs drift, protocols change, and better opportunities appear.",
      "Impermanent loss in LP positions is real. If you're providing liquidity, pair correlated assets (ETH/stETH, USDC/USDT) to minimize it.",
      "Hardware wallets + DeFi = best security combo. Never stake from a hot wallet holding your entire portfolio.",
      "Track your actual realized yield, not just the advertised APY. Fees, slippage, and reward timing all affect real returns.",
      "New protocols often offer higher APYs to attract deposits. Early yields are real, but they won't last — have an exit plan.",
      "Governance tokens earned from staking/farming often lose 60-80% of value. Consider selling rewards regularly rather than holding.",
      "Before bridging assets to chase yield on another chain, factor in bridge fees and the added smart contract risk.",
      "The 'risk-free rate' in DeFi is roughly what USDC lending pays on Aave (~4-6%). Anything above that has additional risk.",
      "Solana staking (via Jito or Marinade) offers 7-8% APY with MEV rewards included. Lower fees make it accessible with smaller amounts.",
      "Never stake more than you can afford to have locked for 30 days. Unbonding periods are real, and markets move fast.",
      "Yield aggregators like DeFiLlama and Vaults.fyi make comparing opportunities across protocols and chains effortless — use them daily.",
      "Consider splitting your portfolio: 60% in stable yield (lending, ETH staking), 30% in moderate (LP, restaking), 10% in aggressive plays.",
      "Bookmark your protocol dashboards and check them with morning coffee. Five minutes of monitoring prevents weeks of missed problems.",
      "The power of compounding at 8% APY: $10,000 becomes $21,589 in 10 years. Start now. Time is your biggest edge.",
      "Airdrops from protocols you're actively using are bonus yield. Track your eligibility on sites like earni.fi.",
      "If a protocol offers 100%+ APY on a non-meme token, the yield is coming from token emissions — and the token is likely inflating away.",
      "Run the numbers on your staking calculator before committing. A 2% APY difference on $10k is only $200/year — is the extra risk worth it?",
      "Multi-sig treasury protocols (like Gnosis Safe) add security for larger portfolios. Worth the setup if you're managing $50k+.",
      "Your first $100/month in passive income is the hardest. After that, you have the knowledge and infrastructure to scale to $500+.",
    ];

    const today = new Date();
    const dayOfYear = Math.floor((today.getTime() - new Date(today.getFullYear(), 0, 0).getTime()) / 86400000);
    const tipIndex = dayOfYear % tips.length;

    const tipEl = document.getElementById('dp-tip-text');
    const dayEl = document.getElementById('dp-tip-day');
    if (tipEl) tipEl.textContent = tips[tipIndex];
    if (dayEl) dayEl.textContent = today.toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' });
  })();

  // 3. Portfolio Earnings
  (function loadPortfolio() {
    const content = document.getElementById('dp-portfolio-content');
    if (!content) return;

    try {
      const saved = localStorage.getItem('yd-portfolio');
      if (!saved) return;

      const portfolio = JSON.parse(saved);
      if (!Array.isArray(portfolio) || portfolio.length === 0) return;

      let totalDailyUsd = 0;
      const lines = [];

      for (const pos of portfolio) {
        const amount = parseFloat(pos.amount) || 0;
        const apy = parseFloat(pos.apy) || 0;
        const price = parseFloat(pos.price) || 0;
        const dailyYield = (amount * price * apy) / 100 / 365;
        totalDailyUsd += dailyYield;
        if (dailyYield > 0.01) {
          lines.push(`${pos.coin || pos.symbol || 'Token'}: ~$${dailyYield.toFixed(2)}/day at ${apy}% APY`);
        }
      }

      if (totalDailyUsd < 0.01) return;

      content.innerHTML = `
        <div class="dp-portfolio-earning">
          <span class="dp-portfolio-amount">~$${totalDailyUsd.toFixed(2)}</span>
          <span class="dp-portfolio-label">estimated today</span>
        </div>
        ${lines.length > 0 ? `<p class="dp-portfolio-detail">${lines.slice(0, 3).join(' · ')}</p>` : ''}
        <a href="/tools/yield-dashboard" class="dp-portfolio-link">View full dashboard &rarr;</a>
      `;
    } catch {
      // If localStorage parse fails, keep showing the empty state
    }
  })();

  // 4. 30-Day Challenge
  (function loadChallenge() {
    const KEY = 'pyl-30day-challenge';
    const btn = document.getElementById('dp-challenge-btn');
    const fill = document.getElementById('dp-challenge-fill');
    const label = document.getElementById('dp-challenge-label');
    if (!btn || !fill || !label) return;

    function getState() {
      try {
        const raw = localStorage.getItem(KEY);
        return raw ? JSON.parse(raw) : null;
      } catch {
        return null;
      }
    }

    function render() {
      const state = getState();
      if (!state || !state.startDate) {
        fill.style.width = '0%';
        label.textContent = 'Day 0 / 30';
        btn.textContent = 'Start the Challenge';
        btn.classList.remove('dp-challenge-btn--active');
        return;
      }

      const start = new Date(state.startDate);
      const now = new Date();
      const dayNum = Math.min(30, Math.max(1, Math.floor((now.getTime() - start.getTime()) / 86400000) + 1));
      const pct = Math.round((dayNum / 30) * 100);

      fill.style.width = pct + '%';
      label.textContent = dayNum >= 30 ? 'Challenge Complete!' : `Day ${dayNum} / 30`;
      btn.textContent = dayNum >= 30 ? 'Restart Challenge' : 'Day ' + dayNum + ' — Keep Going';
      btn.classList.add('dp-challenge-btn--active');
    }

    btn.addEventListener('click', () => {
      const state = getState();
      if (!state || !state.startDate) {
        localStorage.setItem(KEY, JSON.stringify({ startDate: new Date().toISOString() }));
      } else {
        const start = new Date(state.startDate);
        const dayNum = Math.floor((new Date().getTime() - start.getTime()) / 86400000) + 1;
        if (dayNum >= 30) {
          localStorage.setItem(KEY, JSON.stringify({ startDate: new Date().toISOString() }));
        } else {
          window.location.href = '/blog/how-to-earn-passive-income-with-crypto-2026';
        }
      }
      render();
    });

    render();
  })();
</script>
