---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 12);

const categories = [
  { slug: 'staking', label: 'Staking' },
  { slug: 'defi', label: 'DeFi' },
  { slug: 'exchange-reviews', label: 'Exchange Reviews' },
  { slug: 'guides', label: 'Guides' },
  { slug: 'market-analysis', label: 'Market Analysis' },
  { slug: 'tools', label: 'Tools' },
  { slug: 'news', label: 'News' },
];

const levelLabels: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

// Start Here: fixed 3 beginner posts
const startHereSlugs = [
  'how-to-earn-passive-income-with-crypto-2026',
  'best-crypto-passive-income-strategies-2026',
  'how-to-stake-sol-marinade-finance',
];
const startHerePosts = startHereSlugs
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter(Boolean) as typeof allPosts;
---

<BaseLayout title="CryptoYieldGuide" ogImage="/og/default.svg">
  <section class="hero">
    <h1>
      <span class="accent">Earn More</span> From Your Crypto
    </h1>
    <p>
      Practical guides on staking, DeFi yield, exchange lending, and every other
      way to put your crypto to work — written by holders, for holders.
    </p>
    <p class="hero-stat">
      Holders who stake earn <strong>4–12% APY</strong> on assets they already own. We'll show you how.
    </p>
    <p class="hero-loss">
      Every day your crypto sits idle, you're leaving yield on the table.
    </p>
    <a href="/blog" class="hero-cta">Read the Guides</a>
  </section>

  <!-- Start Here -->
  <section class="start-here">
    <div class="start-here-inner">
      <div class="start-here-header">
        <span class="start-here-label">New to crypto passive income?</span>
        <h2>Start Here</h2>
      </div>
      <div class="start-here-grid">
        {startHerePosts.map((post) => (
          <a href={`/blog/${post.id}`} class="start-here-card">
            <div class="start-here-card-badges">
              <span class="card-category">{post.data.category}</span>
              {post.data.level && (
                <span class={`level-badge level-${post.data.level}`}>
                  {levelLabels[post.data.level]}
                </span>
              )}
              {post.data.trending && (
                <span class="trending-badge">🔥 Trending</span>
              )}
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="start-here-read">Read guide &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="category-filter">
    <a href="/blog" class="active">All</a>
    {categories.map((cat) => (
      <a href={`/category/${cat.slug}`}>{cat.label}</a>
    ))}
  </div>

  <section class="article-grid">
    {posts.map((post) => (
      <a href={`/blog/${post.id}`} class="article-card">
        <div class="card-badges">
          <span class="card-category">{post.data.category}</span>
          {post.data.level && (
            <span class={`level-badge level-${post.data.level}`}>
              {levelLabels[post.data.level]}
            </span>
          )}
          {post.data.trending && (
            <span class="trending-badge">🔥 Trending</span>
          )}
        </div>
        <h3>{post.data.title}</h3>
        <p>{post.data.description}</p>
        <div class="card-meta">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })}
          </time>
        </div>
      </a>
    ))}
  </section>

  <section class="email-signup">
    <div class="email-signup-box">
      <h2>Stay in the Loop</h2>
      <p>Get weekly crypto passive income tips straight to your inbox.</p>
      <form
        action="https://app.beehiiv.com/forms/1c80f432-8696-4d95-b028-aa8bd75f08ba"
        method="POST"
        target="_blank"
      >
        <input
          type="email"
          name="email"
          placeholder="you@example.com"
          required
        />
        <button type="submit">Subscribe</button>
      </form>
    </div>
  </section>
</BaseLayout>
