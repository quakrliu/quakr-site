---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const now = new Date();
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.pubDate <= now);
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 12);

const categories = [
  { slug: 'staking', label: 'Staking' },
  { slug: 'defi', label: 'DeFi' },
  { slug: 'ai-income', label: 'AI Income' },
  { slug: 'exchange-reviews', label: 'Exchange Reviews' },
  { slug: 'guides', label: 'Guides' },
  { slug: 'market-analysis', label: 'Market Analysis' },
  { slug: 'tools', label: 'Tools' },
  { slug: 'news', label: 'News' },
  { slug: 'automation', label: 'Automation' },
];

const levelLabels: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

// Start Here: Crypto Yield column (3 posts)
const cryptoYieldSlugs = [
  'how-to-earn-passive-income-with-crypto-2026',
  'best-crypto-passive-income-strategies-2026',
  'how-to-stake-sol-marinade-finance',
];
const cryptoYieldPosts = cryptoYieldSlugs
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter(Boolean) as typeof allPosts;

// Start Here: AI Income column (3 posts)
const aiIncomeSlugs = [
  'make-money-with-ai-2026',
  'ai-freelancing-guide-2026',
  'ai-youtube-channel-guide-2026',
];
const aiIncomePosts = aiIncomeSlugs
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter(Boolean) as typeof allPosts;
---

<BaseLayout title="Passive Yield Lab" ogImage="/og/default.svg">
  <section class="hero">
    <h1>
      <span class="accent">Earn More.</span> Work Less.
    </h1>
    <p>
      Practical guides on crypto yield, AI income, and every smart way to build passive income — tested by real practitioners.
    </p>
    <p class="hero-stat">
      Our readers earn <strong>4–20% APY</strong> on crypto and build <strong>$1K–$10K/month</strong> AI side income. We'll show you how.
    </p>
    <p class="hero-loss">
      Every day your money sits idle, you're leaving yield on the table.
    </p>
    <p class="hero-origin">
      Built by a crypto holder who lost money chasing 300% APY farms. This lab exists so you don't make the same mistakes. <a href="/about" class="hero-origin-link">Our story →</a>
    </p>
    <a href="/blog" class="hero-cta">Read the Guides</a>
  </section>

  <!-- Start Here -->
  <section class="start-here">
    <div class="start-here-inner">
      <div class="start-here-header">
        <span class="start-here-label">New here? Pick your path.</span>
        <h2>Start Here</h2>
      </div>
      <div class="start-here-columns">

        <!-- Left: Crypto Yield -->
        <div class="start-here-column">
          <div class="start-here-column-header">
            <span class="column-icon">&#9670;</span>
            <h3>Crypto Yield</h3>
            <p>Staking, DeFi, lending — earn on what you hold.</p>
          </div>
          <div class="start-here-grid">
            {cryptoYieldPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="start-here-card">
                <div class="start-here-card-badges">
                  <span class="card-category">{post.data.category}</span>
                  {post.data.level && (
                    <span class={`level-badge level-${post.data.level}`}>
                      {levelLabels[post.data.level]}
                    </span>
                  )}
                  {post.data.trending && (
                    <span class="trending-badge">Trending</span>
                  )}
                </div>
                <h4>{post.data.title}</h4>
                <p>{post.data.description}</p>
                <span class="start-here-read">Read guide &rarr;</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Right: AI Income -->
        <div class="start-here-column">
          <div class="start-here-column-header">
            <span class="column-icon column-icon--ai">&#9670;</span>
            <h3>AI Income</h3>
            <p>Build income streams with AI tools and automation.</p>
          </div>
          <div class="start-here-grid">
            {aiIncomePosts.map((post) => (
              <a href={`/blog/${post.id}`} class="start-here-card">
                <div class="start-here-card-badges">
                  <span class="card-category">{post.data.category}</span>
                  {post.data.level && (
                    <span class={`level-badge level-${post.data.level}`}>
                      {levelLabels[post.data.level] || post.data.level}
                    </span>
                  )}
                </div>
                <h4>{post.data.title}</h4>
                <p>{post.data.description}</p>
                <span class="start-here-read">Read guide &rarr;</span>
              </a>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <div class="category-filter">
    <a href="/blog" class="active">All</a>
    {categories.map((cat) => (
      <a href={`/category/${cat.slug}`}>{cat.label}</a>
    ))}
  </div>

  <section class="article-grid">
    {posts.map((post) => (
      <a href={`/blog/${post.id}`} class="article-card">
        <div class="card-badges">
          <span class="card-category">{post.data.category}</span>
          {post.data.level && (
            <span class={`level-badge level-${post.data.level}`}>
              {levelLabels[post.data.level]}
            </span>
          )}
          {post.data.trending && (
            <span class="trending-badge">🔥 Trending</span>
          )}
        </div>
        <h3>{post.data.title}</h3>
        <p>{post.data.description}</p>
        <div class="card-meta">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })}
          </time>
        </div>
      </a>
    ))}
  </section>

  <!-- Lead Magnet Feature -->
  <section class="home-lead-magnet">
    <div class="home-lm-inner">
      <div class="home-lm-text">
        <span class="home-lm-badge">Free Guide</span>
        <h2>The Crypto Bear Market Survival Kit</h2>
        <p>7 passive income strategies that work when prices drop. Real protocols, realistic numbers, step-by-step instructions.</p>
        <a href="/resources/bear-market-survival-kit" class="home-lm-cta">
          Download Free PDF &rarr;
        </a>
      </div>
    </div>
  </section>

  <section class="email-signup">
    <div class="email-signup-box">
      <h2>Your Weekly Yield Edge</h2>
      <p>Every Friday: 1 actionable APY opportunity, 1 platform update, and 1 AI income tip. Free forever.</p>
      <p class="signup-proof">Join readers getting weekly yield picks.</p>
      <form
        action="https://app.beehiiv.com/forms/1c80f432-8696-4d95-b028-aa8bd75f08ba"
        method="POST"
        target="_blank"
      >
        <input
          type="email"
          name="email"
          placeholder="you@example.com"
          required
        />
        <button type="submit">Subscribe</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .start-here-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 1.5rem;
  }

  .start-here-column-header {
    margin-bottom: 1.25rem;
  }

  .start-here-column-header h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--text-primary);
    margin: 0.25rem 0 0.4rem;
    letter-spacing: -0.02em;
  }

  .start-here-column-header p {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
  }

  .column-icon {
    font-size: 0.85rem;
    color: var(--accent);
  }

  .column-icon--ai {
    color: var(--accent);
  }

  .start-here-coming-soon {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .coming-soon-card {
    background: var(--bg-card);
    border: 1px dashed var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .coming-soon-badge {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(74, 144, 217, 0.2);
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    width: fit-content;
    margin-bottom: 0.25rem;
  }

  .coming-soon-card h4 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .coming-soon-card p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* ===== Home Lead Magnet ===== */
  .home-lead-magnet {
    padding: 0 1.5rem;
    margin-bottom: 2rem;
  }

  .home-lm-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    background: linear-gradient(135deg, rgba(27, 58, 92, 0.04) 0%, rgba(74, 144, 217, 0.06) 100%);
    border: 1px solid rgba(74, 144, 217, 0.2);
    border-radius: var(--radius-lg);
    padding: 2.5rem 3rem;
  }

  .home-lm-text {
    max-width: 600px;
  }

  .home-lm-badge {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(74, 144, 217, 0.2);
    padding: 0.2rem 0.65rem;
    border-radius: 9999px;
    margin-bottom: 0.75rem;
  }

  .home-lm-text h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .home-lm-text p {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .home-lm-cta {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.7rem 1.5rem;
    border-radius: var(--radius);
    text-decoration: none;
    box-shadow: var(--shadow-accent);
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .home-lm-cta:hover {
    background: var(--accent-hover);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(74, 144, 217, 0.3);
  }

  @media (max-width: 768px) {
    .start-here-columns {
      grid-template-columns: 1fr;
    }

    .home-lm-inner {
      padding: 2rem 1.5rem;
    }
  }
</style>
