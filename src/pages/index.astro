---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const now = new Date();
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.pubDate <= now);
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const levelLabels: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};
---

<BaseLayout title="Passive Yield Lab — Crypto, AI & Passive Income" ogImage="/og/default.svg">

  <!-- HERO: Split layout — text left, image right -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">Hi, I'm Ethan.</p>
        <h1 class="hero-heading">
          I build passive income systems from Bali — crypto, AI, and everything in between.
          <span class="hero-accent">Real numbers, real mistakes.</span>
        </h1>
        <p class="hero-sub">
          Your idle crypto is losing value every day it sits still.
          I share tested strategies to put it to work — with honest numbers and no fluff.
        </p>
        <div class="hero-actions">
          <a href="/blog" class="btn-primary">Start Here</a>
        </div>
        <p class="hero-proof">80+ guides &nbsp;&middot;&nbsp; 8 free tools</p>
      </div>
      <div class="hero-image">
        <img src="/images/ethan-avatar.png" alt="Ethan Moore" class="hero-portrait" />
      </div>
    </div>
  </section>

  <!-- PODCAST SECTION -->
  <section class="podcast">
    <div class="section-inner">
      <div class="podcast-layout">
        <div class="podcast-text">
          <span class="section-tag">Latest Episode</span>
          <h2 class="section-heading">Listen to the Podcast</h2>
          <p class="section-sub">
            Each week I break down one passive income strategy — what worked, what didn't, and exactly what I'd do differently.
          </p>
          <a href="https://www.youtube.com/@PassiveYieldLab" target="_blank" rel="noopener" class="btn-secondary">
            Watch on YouTube
          </a>
        </div>
        <div class="podcast-embed">
          <div class="yt-wrapper">
            <iframe
              src="https://www.youtube.com/embed/lwx2Psekok8"
              title="Passive Yield Lab — Latest Episode"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- POPULAR GUIDES -->
  <section class="guides">
    <div class="section-inner">
      <div class="guides-header">
        <span class="section-tag">Popular Guides</span>
        <h2 class="section-heading">Pick a strategy. Start earning.</h2>
        <p class="section-sub">Tested frameworks, honest numbers. No guaranteed returns — just real data and what worked for me.</p>
      </div>
      <div class="guides-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="guide-card">
            <div class="guide-card-meta">
              {post.data.category && (
                <span class="tag-category">{post.data.category}</span>
              )}
              {post.data.level && (
                <span class={`tag-level tag-level--${post.data.level}`}>
                  {levelLabels[post.data.level] ?? post.data.level}
                </span>
              )}
            </div>
            <h3 class="guide-card-title">{post.data.title}</h3>
            {post.data.description && (
              <p class="guide-card-desc">{post.data.description}</p>
            )}
            <span class="guide-card-cta">Read guide &rarr;</span>
          </a>
        ))}
      </div>
      <div class="guides-footer">
        <a href="/blog" class="btn-ghost">Browse all guides &rarr;</a>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="newsletter">
    <div class="section-inner">
      <div class="newsletter-inner">
        <div class="newsletter-text">
          <span class="section-tag">Free Newsletter</span>
          <h2 class="newsletter-heading">Weekly yield picks + AI income strategies.</h2>
          <p class="newsletter-sub">
            Every Sunday: one actionable strategy, current APYs, and what I'm actually running.
            Your yield, your strategy — don't miss a week.
          </p>
        </div>
        <form
          class="newsletter-form"
          action="https://subscribe-forms.beehiiv.com/1c80f432-8696-4d95-b028-aa8bd75f08ba"
          method="post"
          target="_blank"
        >
          <div class="newsletter-fields">
            <input
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              class="newsletter-input"
            />
            <button type="submit" class="newsletter-btn">Subscribe Free</button>
          </div>
          <p class="newsletter-note">No spam. Unsubscribe anytime.</p>
        </form>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ---- Shared layout ---- */
.section-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 0 1.5rem;
}

.section-tag {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 0.75rem;
}

.section-heading {
  font-size: clamp(1.6rem, 3vw, 2.1rem);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.25;
  margin-bottom: 0.75rem;
}

.section-sub {
  color: var(--text-secondary);
  font-size: 1rem;
  max-width: 52ch;
  line-height: 1.7;
}

/* ---- Buttons ---- */
.btn-primary {
  display: inline-block;
  background: var(--accent);
  color: #fff;
  font-weight: 600;
  font-size: 0.95rem;
  padding: 0.75rem 1.75rem;
  border-radius: var(--radius);
  text-decoration: none;
  transition: background 0.2s ease, box-shadow 0.2s ease;
}

.btn-primary:hover {
  background: var(--accent-hover);
  box-shadow: var(--shadow-accent);
  color: #fff;
}

.btn-secondary {
  display: inline-block;
  border: 1.5px solid var(--accent);
  color: var(--accent);
  font-weight: 600;
  font-size: 0.95rem;
  padding: 0.7rem 1.6rem;
  border-radius: var(--radius);
  text-decoration: none;
  transition: background 0.2s ease, color 0.2s ease;
}

.btn-secondary:hover {
  background: var(--accent-dim);
  color: var(--accent-hover);
}

.btn-ghost {
  display: inline-block;
  color: var(--accent);
  font-weight: 600;
  font-size: 0.95rem;
  text-decoration: none;
  border-bottom: 1.5px solid var(--accent-dim);
  padding-bottom: 2px;
  transition: border-color 0.2s ease;
}

.btn-ghost:hover {
  border-color: var(--accent);
  color: var(--accent-hover);
}

/* ---- HERO ---- */
.hero {
  padding: 6rem 1.5rem 5rem;
  background: var(--bg-primary);
}

.hero-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 3rem;
  align-items: center;
}

.hero-content {
  max-width: 62ch;
}

.hero-image {
  display: flex;
  justify-content: center;
  align-items: center;
}

.hero-portrait {
  width: 250px;
  height: 250px;
  border-radius: 50%;
  object-fit: cover;
  box-shadow: 0 8px 30px rgba(0,0,0,0.12);
}

@media (max-width: 768px) {
  .hero-inner {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .hero-image {
    order: -1;
  }
  .hero-portrait {
    width: 180px;
    height: 180px;
  }
}

.hero-eyebrow {
  font-size: 1.1rem;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 1.1rem;
}

.hero-heading {
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 800;
  line-height: 1.15;
  color: var(--text-primary);
  margin-bottom: 1.5rem;
}

.hero-accent {
  display: block;
  color: var(--accent);
}

.hero-sub {
  font-size: 1.05rem;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 2rem;
  max-width: 52ch;
}

.hero-actions {
  margin-bottom: 1.25rem;
}

.hero-proof {
  font-size: 0.85rem;
  color: var(--text-muted);
  letter-spacing: 0.02em;
}

/* ---- PODCAST ---- */
.podcast {
  padding: 5rem 0;
  background: var(--bg-secondary);
}

.podcast-layout {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 4rem;
  align-items: center;
}

.podcast-text .section-heading {
  margin-top: 0;
}

.podcast-text .section-sub {
  margin-bottom: 1.75rem;
}

.yt-wrapper {
  position: relative;
  padding-bottom: 56.25%;
  height: 0;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.yt-wrapper iframe {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* ---- GUIDES ---- */
.guides {
  padding: 5rem 0;
  background: var(--bg-primary);
}

.guides-header {
  margin-bottom: 2.5rem;
}

.guides-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
  margin-bottom: 2.5rem;
}

.guide-card {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding: 1.5rem;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  background: var(--bg-card);
  text-decoration: none;
  transition: box-shadow 0.2s ease, border-color 0.2s ease;
}

.guide-card:hover {
  box-shadow: var(--shadow-md);
  border-color: var(--border-hover);
}

.guide-card-meta {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
}

.tag-category {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--accent);
  background: var(--accent-dim);
  padding: 0.2rem 0.55rem;
  border-radius: 4px;
}

.tag-level {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  padding: 0.2rem 0.55rem;
  border-radius: 4px;
}

.tag-level--beginner {
  background: #e6f4ea;
  color: #2d7a3a;
}

.tag-level--intermediate {
  background: #fef3e0;
  color: #a05c00;
}

.tag-level--advanced {
  background: #fde8e8;
  color: #b52a2a;
}

.guide-card-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.35;
  margin-top: 0.25rem;
}

.guide-card-desc {
  font-size: 0.88rem;
  color: var(--text-secondary);
  line-height: 1.6;
  flex: 1;
}

.guide-card-cta {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--accent);
  margin-top: 0.5rem;
}

.guides-footer {
  text-align: left;
}

/* ---- NEWSLETTER ---- */
.newsletter {
  padding: 5rem 0;
  background: var(--bg-secondary);
}

.newsletter-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.newsletter-heading {
  font-size: clamp(1.5rem, 2.5vw, 2rem);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.25;
  margin-bottom: 0.75rem;
}

.newsletter-sub {
  color: var(--text-secondary);
  font-size: 0.97rem;
  line-height: 1.7;
}

.newsletter-fields {
  display: flex;
  gap: 0.6rem;
  margin-bottom: 0.6rem;
}

.newsletter-input {
  flex: 1;
  padding: 0.75rem 1rem;
  border: 1.5px solid var(--border);
  border-radius: var(--radius);
  font-size: 0.95rem;
  font-family: var(--font-body);
  color: var(--text-primary);
  background: var(--bg-primary);
  outline: none;
  transition: border-color 0.2s ease;
}

.newsletter-input:focus {
  border-color: var(--accent);
}

.newsletter-btn {
  padding: 0.75rem 1.4rem;
  background: var(--accent);
  color: #fff;
  font-weight: 600;
  font-size: 0.95rem;
  font-family: var(--font-body);
  border: none;
  border-radius: var(--radius);
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.2s ease;
}

.newsletter-btn:hover {
  background: var(--accent-hover);
}

.newsletter-note {
  font-size: 0.78rem;
  color: var(--text-muted);
}

/* ---- RESPONSIVE ---- */
@media (max-width: 900px) {
  .podcast-layout {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .guides-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .newsletter-inner {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
}

@media (max-width: 600px) {
  .hero {
    padding: 4rem 1.25rem 3.5rem;
  }

  .guides-grid {
    grid-template-columns: 1fr;
  }

  .newsletter-fields {
    flex-direction: column;
  }

  .newsletter-btn {
    width: 100%;
  }
}
</style>
