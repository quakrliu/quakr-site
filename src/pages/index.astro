---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const now = new Date();
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.pubDate <= now);
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 12);

const categories = [
  { slug: 'staking', label: 'Staking' },
  { slug: 'defi', label: 'DeFi' },
  { slug: 'ai-income', label: 'AI Income' },
  { slug: 'exchange-reviews', label: 'Exchange Reviews' },
  { slug: 'guides', label: 'Guides' },
  { slug: 'market-analysis', label: 'Market Analysis' },
  { slug: 'tools', label: 'Tools' },
  { slug: 'news', label: 'News' },
  { slug: 'automation', label: 'Automation' },
  { slug: 'investing', label: 'Investing' },
];

const levelLabels: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

// Start Here: Crypto Yield column (3 posts)
const cryptoYieldSlugs = [
  'how-to-earn-passive-income-with-crypto-2026',
  'best-crypto-passive-income-strategies-2026',
  'how-to-stake-sol-marinade-finance',
];
const cryptoYieldPosts = cryptoYieldSlugs
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter(Boolean) as typeof allPosts;

// Start Here: AI Income column (3 posts)
const aiIncomeSlugs = [
  'make-money-with-ai-2026',
  'ai-freelancing-guide-2026',
  'ai-youtube-channel-guide-2026',
];
const aiIncomePosts = aiIncomeSlugs
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter(Boolean) as typeof allPosts;

// Featured post (latest)
const featuredPost = posts[0];
const remainingPosts = posts.slice(1, 9);

// Stats
const totalArticles = allPosts.length;
const totalCategories = categories.length;
---

<BaseLayout title="Passive Yield Lab" ogImage="/og/default.svg">

  <!-- HERO: Asymmetric split — Octalysis #1 Epic Meaning + #8 Loss Avoidance -->
  <section class="hp-hero">
    <div class="hp-hero-inner">
      <div class="hp-hero-text">
        <span class="hp-hero-tag">Crypto Yield + AI Income Lab</span>
        <h1>
          Your idle crypto is losing value.<br />
          <span class="hp-hero-accent">Put it to work.</span>
        </h1>
        <p class="hp-hero-desc">
          Practical, tested guides on earning 4-20% APY through staking, DeFi, and lending — plus AI-powered income strategies that actually work. Built by practitioners who lost money so you don't have to.
        </p>
        <p class="hp-hero-milestone">
          Your goal: go from $0 to your first $100/month in passive income. We'll show you how, step by step.
        </p>
        <div class="hp-hero-actions">
          <a href="/blog" class="hp-btn-primary">Read the Guides</a>
          <a href="/tools/staking-calculator" class="hp-btn-secondary">Calculate Your Yield</a>
        </div>
      </div>
      <div class="hp-hero-aside">
        <div class="hp-hero-proof">
          <div class="hp-proof-line">
            <span class="hp-proof-number">{totalArticles}</span>
            <span class="hp-proof-text">in-depth guides</span>
          </div>
          <span class="hp-proof-divider">·</span>
          <div class="hp-proof-line">
            <span class="hp-proof-number">3</span>
            <span class="hp-proof-text">free tools</span>
          </div>
          <span class="hp-proof-divider">·</span>
          <div class="hp-proof-line">
            <span class="hp-proof-number">0</span>
            <span class="hp-proof-text">fluff</span>
          </div>
        </div>
        <div class="hp-hero-calc">
          <p class="hp-calc-hook">How much is your idle crypto costing you?</p>
          <p class="hp-calc-example">$10,000 at 5% APY = <strong>$9.60/week</strong> in missed yield</p>
          <a href="/tools/yield-dashboard" class="hp-btn-calc">See your number →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- TOOLS: Octalysis #3 Empowerment + #4 Ownership -->
  <section class="hp-tools">
    <div class="hp-tools-inner">
      <div class="hp-section-header">
        <span class="hp-section-tag">Your Toolkit</span>
        <h2>Build your portfolio with real data</h2>
        <p>Your numbers, your strategy. Model, track, and optimize your passive income with tools built for practitioners.</p>
      </div>
      <div class="hp-tools-grid">
        <a href="/tools/yield-dashboard" class="hp-tool-card hp-tool-card--wide">
          <div class="hp-tool-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          </div>
          <h3>Yield Dashboard</h3>
          <p>Track staking yields across protocols. Compare APYs. Find the best opportunities right now.</p>
          <span class="hp-tool-cta">Open Dashboard &rarr;</span>
        </a>
        <a href="/tools/staking-calculator" class="hp-tool-card">
          <div class="hp-tool-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="16" y1="14" x2="16" y2="18"/><line x1="8" y1="10" x2="8" y2="10.01"/><line x1="12" y1="10" x2="12" y2="10.01"/><line x1="16" y1="10" x2="16" y2="10.01"/><line x1="8" y1="14" x2="8" y2="14.01"/><line x1="12" y1="14" x2="12" y2="14.01"/><line x1="8" y1="18" x2="8" y2="18.01"/><line x1="12" y1="18" x2="12" y2="18.01"/></svg>
          </div>
          <h3>Staking Calculator</h3>
          <p>Model your rewards. See exactly what your holdings could earn.</p>
          <span class="hp-tool-cta">Calculate &rarr;</span>
        </a>
        <a href="/tools/aeo-audit" class="hp-tool-card">
          <div class="hp-tool-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <h3>AEO Audit</h3>
          <p>Check how your content performs for AI Engine Optimization.</p>
          <span class="hp-tool-cta">Run Audit &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- START HERE: Octalysis #2 Accomplishment + #7 Curiosity -->
  <section class="start-here">
    <div class="start-here-inner">
      <div class="start-here-header">
        <span class="hp-section-tag">New here? Pick your path.</span>
        <h2>Start Here</h2>
        <p>Two proven tracks to passive income. Choose the one that fits you — and finish your first guide today.</p>
        <div class="start-here-progress">
          <div class="progress-step">
            <span class="progress-num">1</span>
            <span class="progress-text">Pick a path</span>
          </div>
          <span class="progress-arrow">&rarr;</span>
          <div class="progress-step">
            <span class="progress-num">2</span>
            <span class="progress-text">Read the starter guide</span>
          </div>
          <span class="progress-arrow">&rarr;</span>
          <div class="progress-step">
            <span class="progress-num">3</span>
            <span class="progress-text">Earn your first yield</span>
          </div>
        </div>
      </div>
      <div class="start-here-columns">

        <!-- Left: Crypto Yield -->
        <div class="start-here-column">
          <div class="start-here-column-header">
            <span class="column-icon">&#9670;</span>
            <h3>Crypto Yield</h3>
            <p>Staking, DeFi, lending — earn on what you hold.</p>
          </div>
          <div class="start-here-grid">
            {cryptoYieldPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="start-here-card">
                <div class="start-here-card-badges">
                  <span class="card-category">{post.data.category}</span>
                  {post.data.level && (
                    <span class={`level-badge level-${post.data.level}`}>
                      {levelLabels[post.data.level]}
                    </span>
                  )}
                  {post.data.trending && (
                    <span class="trending-badge">Trending</span>
                  )}
                </div>
                <h4>{post.data.title}</h4>
                <p>{post.data.description}</p>
                <span class="start-here-read">Read guide &rarr;</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Right: AI Income -->
        <div class="start-here-column">
          <div class="start-here-column-header">
            <span class="column-icon column-icon--ai">&#9670;</span>
            <h3>AI Income</h3>
            <p>Build income streams with AI tools and automation.</p>
          </div>
          <div class="start-here-grid">
            {aiIncomePosts.map((post) => (
              <a href={`/blog/${post.id}`} class="start-here-card">
                <div class="start-here-card-badges">
                  <span class="card-category">{post.data.category}</span>
                  {post.data.level && (
                    <span class={`level-badge level-${post.data.level}`}>
                      {levelLabels[post.data.level] || post.data.level}
                    </span>
                  )}
                </div>
                <h4>{post.data.title}</h4>
                <p>{post.data.description}</p>
                <span class="start-here-read">Read guide &rarr;</span>
              </a>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- FEATURED + LATEST: Asymmetric zig-zag layout -->
  {featuredPost && (
    <section class="hp-featured">
      <div class="hp-featured-inner">
        <div class="hp-section-header">
          <span class="hp-section-tag">Latest</span>
          <h2>Fresh from the Lab</h2>
        </div>
        <a href={`/blog/${featuredPost.id}`} class="hp-featured-card">
          <div class="hp-featured-meta">
            <span class="card-category">{featuredPost.data.category}</span>
            {featuredPost.data.level && (
              <span class={`level-badge level-${featuredPost.data.level}`}>
                {levelLabels[featuredPost.data.level]}
              </span>
            )}
            {featuredPost.data.trending && (
              <span class="trending-badge">Trending</span>
            )}
            <time datetime={featuredPost.data.pubDate.toISOString()}>
              {featuredPost.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </div>
          <h3>{featuredPost.data.title}</h3>
          <p>{featuredPost.data.description}</p>
          <span class="hp-featured-read">Read this guide &rarr;</span>
        </a>
      </div>
    </section>
  )}

  <!-- CATEGORY NAV -->
  <div class="category-filter">
    <a href="/blog" class="active">All</a>
    {categories.map((cat) => (
      <a href={`/category/${cat.slug}`}>{cat.label}</a>
    ))}
  </div>

  <!-- ARTICLE GRID: Asymmetric 2-column + 1 wide pattern -->
  <section class="hp-articles">
    <div class="hp-articles-grid">
      {remainingPosts.map((post, i) => (
        <a
          href={`/blog/${post.id}`}
          class={`article-card ${i === 0 ? 'article-card--wide' : ''}`}
        >
          <div class="card-badges">
            <span class="card-category">{post.data.category}</span>
            {post.data.level && (
              <span class={`level-badge level-${post.data.level}`}>
                {levelLabels[post.data.level]}
              </span>
            )}
            {post.data.trending && (
              <span class="trending-badge">Trending</span>
            )}
          </div>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          <div class="card-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </div>
        </a>
      ))}
    </div>
    <div class="hp-articles-more">
      <a href="/blog" class="hp-btn-secondary">View All Guides &rarr;</a>
    </div>
  </section>

  <!-- LEAD MAGNET: Octalysis #6 Scarcity + #7 Curiosity -->
  <section class="home-lead-magnet">
    <div class="home-lm-inner">
      <div class="home-lm-text">
        <span class="home-lm-badge">Free Guide</span>
        <h2>The Crypto Bear Market Survival Kit</h2>
        <p>7 passive income strategies that work when prices drop. Real protocols, realistic numbers, step-by-step instructions. Includes APY snapshots that update quarterly — grab the latest version.</p>
        <a href="/resources/bear-market-survival-kit" class="home-lm-cta">
          Download Free PDF &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- EMAIL SIGNUP: Octalysis #5 Social Influence + #2 Accomplishment -->
  <section class="email-signup">
    <iframe src="https://subscribe-forms.beehiiv.com/1c80f432-8696-4d95-b028-aa8bd75f08ba" class="beehiiv-embed" data-test-id="beehiiv-embed" frameborder="0" scrolling="no" style="width: 100%; max-width: 600px; height: 340px; margin: 0 auto; display: block; background-color: transparent; border-radius: 12px;"></iframe>
  </section>
</BaseLayout>

<style>
  /* ===== Hero: Asymmetric Split ===== */
  .hp-hero {
    padding: 5rem 1.5rem 3rem;
    position: relative;
    overflow: hidden;
  }

  .hp-hero::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -200px;
    width: 700px;
    height: 700px;
    background: radial-gradient(ellipse at center, rgba(74, 144, 217, 0.06) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  .hp-hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 4rem;
    align-items: start;
    position: relative;
    z-index: 1;
  }

  .hp-hero-tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(74, 144, 217, 0.15);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    margin-bottom: 1.25rem;
  }

  .hp-hero-text h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .hp-hero-accent {
    color: var(--accent);
  }

  .hp-hero-desc {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 540px;
    margin-bottom: 2rem;
  }

  .hp-hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hp-btn-primary {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    padding: 0.8rem 2rem;
    border-radius: var(--radius);
    font-size: 0.95rem;
    box-shadow: var(--shadow-accent);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    text-decoration: none;
  }

  .hp-btn-primary:hover {
    background: var(--accent-hover);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(74, 144, 217, 0.3);
  }

  .hp-btn-primary:active {
    transform: translateY(0) scale(0.98);
  }

  .hp-btn-secondary {
    display: inline-block;
    color: var(--accent);
    font-family: var(--font-display);
    font-weight: 600;
    padding: 0.8rem 2rem;
    border-radius: var(--radius);
    font-size: 0.95rem;
    border: 1px solid var(--border);
    background: var(--bg-primary);
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
    text-decoration: none;
  }

  .hp-btn-secondary:hover {
    border-color: var(--accent);
    background: var(--accent-dim);
    color: var(--accent);
    transform: translateY(-1px);
  }

  .hp-btn-secondary:active {
    transform: translateY(0) scale(0.98);
  }

  /* Hero aside */
  .hp-hero-aside {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 2.5rem;
  }

  .hp-hero-proof {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hp-proof-line {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .hp-proof-number {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }

  .hp-proof-text {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .hp-proof-divider {
    color: var(--border);
    font-size: 1.25rem;
  }

  .hp-hero-calc {
    background: linear-gradient(135deg, rgba(27, 58, 92, 0.04) 0%, rgba(74, 144, 217, 0.06) 100%);
    border: 1px solid rgba(74, 144, 217, 0.15);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
  }

  .hp-calc-hook {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
  }

  .hp-calc-example {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0 0 1rem;
  }

  .hp-calc-example strong {
    color: var(--accent);
    font-weight: 700;
  }

  .hp-btn-calc {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    transition: color 0.2s;
  }

  .hp-btn-calc:hover {
    color: var(--text-primary);
  }

  .hp-stat-value {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.03em;
  }

  .hp-stat-sub {
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .hp-hero-loss {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border-light);
  }

  .hp-hero-milestone {
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 1.5rem;
    padding: 0.6rem 1rem;
    background: var(--accent-dim);
    border-left: 3px solid var(--accent);
    border-radius: 0 var(--radius) var(--radius) 0;
    max-width: 540px;
  }

  .hp-hero-urgency {
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border-light);
  }

  .hp-hero-cost {
    font-size: 0.82rem;
    color: var(--text-secondary);
    margin-top: 0.4rem;
    line-height: 1.55;
  }

  /* ===== Section shared styles ===== */
  .hp-section-header {
    margin-bottom: 2rem;
  }

  .hp-section-tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(74, 144, 217, 0.15);
    padding: 0.2rem 0.65rem;
    border-radius: 9999px;
    margin-bottom: 0.75rem;
  }

  .hp-section-header h2 {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.025em;
    margin-bottom: 0.35rem;
  }

  .hp-section-header p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    max-width: 520px;
  }

  /* ===== Tools Section ===== */
  .hp-tools {
    padding: 2rem 1.5rem 3rem;
    background: var(--bg-secondary);
  }

  .hp-tools-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .hp-tools-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 1rem;
  }

  .hp-tool-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.2s, box-shadow 0.3s;
  }

  .hp-tool-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: 0 12px 32px rgba(27, 58, 92, 0.08);
    color: inherit;
  }

  .hp-tool-card:active {
    transform: translateY(-1px) scale(0.995);
  }

  .hp-tool-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--accent-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
  }

  .hp-tool-card h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .hp-tool-card p {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.6;
    flex-grow: 1;
  }

  .hp-tool-cta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
  }

  /* ===== Start Here (inherited) ===== */
  .start-here {
    padding: 3rem 1.5rem;
  }

  .start-here-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .start-here-header {
    margin-bottom: 2rem;
  }

  .start-here-header h2 {
    font-family: var(--font-display);
