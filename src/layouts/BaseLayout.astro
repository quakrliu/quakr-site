---
import '@/styles/global.css';
import { generateWebsiteSchema } from '@/utils/seo';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  category?: string;
  canonicalUrl?: string;
  articleSchema?: string;
  extraSchemas?: string[];
}

const {
  title,
  description = 'Practical guides on every way to build passive income — crypto, AI, dividends, real estate, digital products, and more. Tested by real practitioners.',
  ogImage,
  ogType = 'website',
  category,
  canonicalUrl,
  articleSchema,
  extraSchemas = [],
} = Astro.props;

const SITE_URL = 'https://passiveyieldlab.com';

const categoryOgMap: Record<string, string> = {
  staking: '/og/staking.svg',
  defi: '/og/defi.svg',
  guides: '/og/guides.svg',
  tools: '/og/tools.svg',
  news: '/og/news.svg',
  'exchange-reviews': '/og/default.svg',
  'ai-income': '/og/default.svg',
  automation: '/og/default.svg',
  investing: '/og/default.svg',
};

const resolvedOgImageRel = ogImage || (category ? (categoryOgMap[category] ?? '/og/default.svg') : '/og/default.svg');
const resolvedOgImage = resolvedOgImageRel.startsWith('http') ? resolvedOgImageRel : SITE_URL + resolvedOgImageRel;

const siteTitle = title === 'Passive Yield Lab' ? title : `${title} | Passive Yield Lab`;
const websiteSchema = generateWebsiteSchema();
const canonical = canonicalUrl || Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Passive Yield Lab RSS"
      href="/rss.xml"
    />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Passive Yield Lab" />
    <meta property="og:image" content={resolvedOgImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={websiteSchema} />
    {articleSchema && (
      <script type="application/ld+json" set:html={articleSchema} />
    )}
    {extraSchemas.map((s) => (
      <script type="application/ld+json" set:html={s} />
    ))}
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <img src="/logo-nav.png" alt="Passive Yield Lab" class="nav-logo-img" width="42" height="42" />
          <span class="nav-logo-text">Passive Yield <span class="nav-logo-accent">Lab</span></span>
        </a>
        <button class="nav-toggle" aria-label="Toggle menu" id="nav-toggle">
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
        </button>
        <ul class="nav-links" id="nav-links">
          <li><a href="/category/ai-income">AI Income</a></li>
          <li><a href="/blog">Crypto Yield</a></li>
          <li><a href="/category/guides">Guides</a></li>
          <li class="nav-dropdown">
            <a href="/tools/yield-dashboard" class="nav-link-tools">
              Tools
              <span class="nav-badge">NEW</span>
            </a>
            <ul class="nav-dropdown-menu">
              <li><a href="/tools/yield-dashboard">Yield Dashboard</a></li>
              <li><a href="/tools/staking-calculator">Staking Calculator</a></li>
              <li><a href="/tools/aeo-audit">AEO Audit</a></li>
              <li><a href="/tools/impermanent-loss-calculator">IL Calculator</a></li>
              <li><a href="/tools/crypto-tax-estimator">Tax Estimator</a></li>
              <li><a href="/tools/defi-risk-score">DeFi Risk Score</a></li>
              <li><a href="/tools/yield-compounding">Compounding Sim</a></li>
              <li><a href="/tools/airdrop-checker">Airdrop Checker</a></li>
            </ul>
          </li>
          <li><a href="/resources">Resources</a></li>
          <li><a href="/about">About</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <ul class="footer-links">
          <li><a href="/about">About</a></li>
          <li><a href="/disclaimer">Disclaimer</a></li>
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/rss.xml">RSS</a></li>
          <li>
            <a href="https://x.com/quakrdev" target="_blank" rel="noopener noreferrer" aria-label="Follow Passive Yield Lab on X (Twitter)" class="footer-social-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="vertical-align:-2px;margin-right:4px">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              Follow on X
            </a>
          </li>
        </ul>
        <p class="footer-copy">
          &copy; {new Date().getFullYear()} Passive Yield Lab. Not financial advice.
        </p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('nav-toggle');
      const navLinks = document.getElementById('nav-links');
      toggle?.addEventListener('click', () => {
        const isOpen = navLinks?.classList.toggle('open');
        toggle.classList.toggle('active', isOpen);
        toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });

      // Highlight active nav link
      const currentPath = window.location.pathname;
      document.querySelectorAll('.nav-links a').forEach((link) => {
        const href = link.getAttribute('href');
        if (href && (currentPath === href || (href !== '/' && currentPath.startsWith(href)))) {
          link.setAttribute('aria-current', 'page');
        }
      });

      // Scroll-aware nav opacity
      window.addEventListener('scroll', () => {
        const nav = document.querySelector('.nav');
        if (window.scrollY > 20) {
          nav?.classList.add('scrolled');
        } else {
          nav?.classList.remove('scrolled');
        }
      });
    </script>
    <script>
      import '../scripts/gsap-animations.js';
    </script>
  </body>
</html>
