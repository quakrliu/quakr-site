---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import { generateArticleSchema } from '@/utils/seo';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags?: string[];
  affiliateLinks?: { name: string; url: string; cta?: string }[];
  seoTitle?: string;
  seoDescription?: string;
  canonicalUrl?: string;
  ogImage?: string;
  level?: 'beginner' | 'intermediate' | 'advanced';
  trending?: boolean;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags = [],
  affiliateLinks = [],
  seoTitle,
  seoDescription,
  canonicalUrl,
  ogImage,
  level,
  trending = false,
} = Astro.props;

const articleSchema = generateArticleSchema({
  title: seoTitle || title,
  description: seoDescription || description,
  url: canonicalUrl || Astro.url.href,
  pubDate,
  updatedDate,
  ogImage,
});

const wordCount = (await Astro.slots.render('default')).split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const categoryLabels: Record<string, string> = {
  staking: 'Staking',
  defi: 'DeFi',
  'exchange-reviews': 'Exchange Reviews',
  guides: 'Guides',
  'market-analysis': 'Market Analysis',
  tools: 'Tools',
  news: 'News',
};

const levelLabels: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

// Related articles: same category 2 posts + different category 1 post (S6)
const now = new Date();
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.pubDate <= now);
const currentUrl = Astro.url.pathname;
const sameCatPosts = allPosts
  .filter((p) => p.data.category === category && `/blog/${p.id}` !== currentUrl)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
const diffCatCandidates = allPosts
  .filter((p) => p.data.category !== category && `/blog/${p.id}` !== currentUrl);
const randomDiffCat = diffCatCandidates.length > 0
  ? [diffCatCandidates[Math.floor(Math.random() * diffCatCandidates.length)]]
  : [];
const relatedPosts = [...sameCatPosts, ...randomDiffCat];

// Share on X
const shareText = encodeURIComponent(`${title} via @quakrdev`);
const shareUrl = encodeURIComponent(Astro.url.href);
const twitterShareUrl = `https://x.com/intent/tweet?text=${shareText}&url=${shareUrl}`;
---

<BaseLayout
  title={seoTitle || title}
  description={seoDescription || description}
  ogImage={ogImage}
  category={category}
  canonicalUrl={canonicalUrl}
  articleSchema={articleSchema}
>
  <div class="affiliate-disclosure">
    <strong>Disclosure:</strong> This article may contain affiliate links. We earn
    a commission at no extra cost to you if you sign up through our links. We only
    recommend products we use and trust.
  </div>

  {category === 'news' && (
    <div class="news-alert-banner">
      ⚡ Breaking: This directly affects your yield strategy. Read carefully.
    </div>
  )}

  <header class="post-header">
    <div class="post-header-badges">
      <a href={`/category/${category}`} class="post-category">
        {categoryLabels[category] || category}
      </a>
      {level && (
        <span class={`level-badge level-${level}`}>
          {levelLabels[level]}
        </span>
      )}
      {trending && (
        <span class="trending-badge">🔥 Trending</span>
      )}
    </div>
    <h1>{title}</h1>
    <div class="post-meta">
      <time datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
      {updatedDate && (
        <span class="updated-date">
          Last updated:{' '}
          <time datetime={updatedDate.toISOString()}>
            {updatedDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        </span>
      )}
      <span>{readingTime} min read</span>
    </div>
  </header>

  <article class="post-content">
    <slot />
  </article>

  {affiliateLinks.length > 0 && (
    <div class="post-content">
      {affiliateLinks.map((link) => (
        <div class="affiliate-cta">
          <h3>{link.cta || `Try ${link.name}`}</h3>
          <p>
            Sign up with our referral link and start earning passive income
            today.
          </p>
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class="cta-button"
          >
            Get Started with {link.name} &rarr;
          </a>
        </div>
      ))}
    </div>
  )}

  {tags.length > 0 && (
    <div class="post-content">
      <div class="tags">
        {tags.map((tag) => (
          <a href={`/blog?tag=${tag}`}>#{tag}</a>
        ))}
      </div>
    </div>
  )}

  <!-- Share on X -->
  <div class="post-content post-share">
    <a
      href={twitterShareUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="share-x-btn"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
      Share on X
    </a>
  </div>

  <!-- Email CTA -->
  <div class="post-content">
    <div class="post-email-cta">
      <h2>Get Smarter About Passive Income</h2>
      <p>Weekly crypto yield picks + AI income strategies. Join readers.</p>
      <p class="signup-proof">Join readers getting weekly yield picks.</p>
      <form
        action="https://app.beehiiv.com/forms/1c80f432-8696-4d95-b028-aa8bd75f08ba"
        method="POST"
        target="_blank"
        class="post-email-form"
      >
        <input
          type="email"
          name="email"
          placeholder="you@example.com"
          required
        />
        <button type="submit">Get Free Tips</button>
      </form>
    </div>
  </div>

  <!-- Related Articles -->
  {relatedPosts.length > 0 && (
    <div class="post-content">
      <div class="related-articles">
        <h2 class="related-heading">Keep Reading</h2>
        <div class="related-grid">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.id}`} class="related-card">
              <div class="related-card-top">
                <span class="card-category">{post.data.category}</span>
                {post.data.level && (
                  <span class={`level-badge level-${post.data.level}`}>
                    {levelLabels[post.data.level]}
                  </span>
                )}
                {post.data.trending && (
                  <span class="trending-badge">🔥 Trending</span>
                )}
              </div>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <span class="related-read-more">Read article &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}
</BaseLayout>
