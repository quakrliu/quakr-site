---
import BaseLayout from './BaseLayout.astro';
import { generateArticleSchema } from '@/utils/seo';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags?: string[];
  affiliateLinks?: { name: string; url: string; cta?: string }[];
  seoTitle?: string;
  seoDescription?: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags = [],
  affiliateLinks = [],
  seoTitle,
  seoDescription,
  canonicalUrl,
  ogImage,
} = Astro.props;

const articleSchema = generateArticleSchema({
  title: seoTitle || title,
  description: seoDescription || description,
  url: canonicalUrl || Astro.url.href,
  pubDate,
  updatedDate,
  ogImage,
});

const wordCount = (await Astro.slots.render('default')).split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const categoryLabels: Record<string, string> = {
  staking: 'Staking',
  defi: 'DeFi',
  'exchange-reviews': 'Exchange Reviews',
  guides: 'Guides',
  'market-analysis': 'Market Analysis',
  tools: 'Tools',
  news: 'News',
};
---

<BaseLayout
  title={seoTitle || title}
  description={seoDescription || description}
  ogImage={ogImage}
  canonicalUrl={canonicalUrl}
  articleSchema={articleSchema}
>
  <div class="affiliate-disclosure">
    <strong>Disclosure:</strong> This article may contain affiliate links. We earn
    a commission at no extra cost to you if you sign up through our links. We only
    recommend products we use and trust.
  </div>

  <header class="post-header">
    <a href={`/category/${category}`} class="post-category">
      {categoryLabels[category] || category}
    </a>
    <h1>{title}</h1>
    <div class="post-meta">
      <time datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
      <span>{readingTime} min read</span>
    </div>
  </header>

  <article class="post-content">
    <slot />
  </article>

  {affiliateLinks.length > 0 && (
    <div class="post-content">
      {affiliateLinks.map((link) => (
        <div class="affiliate-cta">
          <h3>{link.cta || `Try ${link.name}`}</h3>
          <p>
            Sign up with our referral link and start earning passive income
            today.
          </p>
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class="cta-button"
          >
            Get Started with {link.name} &rarr;
          </a>
        </div>
      ))}
    </div>
  )}

  {tags.length > 0 && (
    <div class="post-content">
      <div class="tags">
        {tags.map((tag) => (
          <a href={`/blog?tag=${tag}`}>#{tag}</a>
        ))}
      </div>
    </div>
  )}
</BaseLayout>
