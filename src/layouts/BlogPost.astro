---
import BaseLayout from './BaseLayout.astro';
import AdSense from '../components/AdSense.astro';
import { getCollection } from 'astro:content';
import { generateArticleSchema } from '@/utils/seo';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags?: string[];
  affiliateLinks?: { name: string; url: string; cta?: string }[];
  seoTitle?: string;
  seoDescription?: string;
  canonicalUrl?: string;
  ogImage?: string;
  level?: 'beginner' | 'intermediate' | 'advanced';
  trending?: boolean;
  extraSchemas?: string[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags = [],
  affiliateLinks = [],
  seoTitle,
  seoDescription,
  canonicalUrl,
  ogImage,
  level,
  trending = false,
  extraSchemas = [],
} = Astro.props;

const articleSchema = generateArticleSchema({
  title: seoTitle || title,
  description: seoDescription || description,
  url: canonicalUrl || Astro.url.href,
  pubDate,
  updatedDate,
  ogImage,
});

const wordCount = (await Astro.slots.render('default')).split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const categoryLabels: Record<string, string> = {
  staking: 'Staking',
  defi: 'DeFi',
  'exchange-reviews': 'Exchange Reviews',
  guides: 'Guides',
  'market-analysis': 'Market Analysis',
  tools: 'Tools',
  news: 'News',
};

const levelLabels: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

// Related articles: same category 2 posts + different category 1 post (S6)
const now = new Date();
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.pubDate <= now);
const currentUrl = Astro.url.pathname;
const sameCatPosts = allPosts
  .filter((p) => p.data.category === category && `/blog/${p.id}` !== currentUrl)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
const diffCatCandidates = allPosts
  .filter((p) => p.data.category !== category && `/blog/${p.id}` !== currentUrl);
const randomDiffCat = diffCatCandidates.length > 0
  ? [diffCatCandidates[Math.floor(Math.random() * diffCatCandidates.length)]]
  : [];
const relatedPosts = [...sameCatPosts, ...randomDiffCat];

// Share URLs
const shareText = encodeURIComponent(`${title} via @quakrdev`);
const shareUrl = encodeURIComponent(Astro.url.href);
const twitterShareUrl = `https://x.com/intent/tweet?text=${shareText}&url=${shareUrl}`;
const redditShareUrl = `https://www.reddit.com/submit?url=${shareUrl}&title=${encodeURIComponent(seoTitle || title)}`;
const linkedinShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`;
---

<BaseLayout
  title={seoTitle || title}
  description={seoDescription || description}
  ogImage={ogImage}
  ogType="article"
  category={category}
  canonicalUrl={canonicalUrl}
  articleSchema={articleSchema}
  extraSchemas={extraSchemas}
>
  <div class="affiliate-disclosure">
    <strong>Disclosure:</strong> This article may contain affiliate links. We earn
    a commission at no extra cost to you if you sign up through our links. We only
    recommend products we use and trust.
  </div>

  {category === 'news' && (
    <div class="news-alert-banner">
      ⚡ Breaking: This directly affects your yield strategy. Read carefully.
    </div>
  )}

  <header class="post-header">
    <div class="post-header-badges">
      <a href={`/category/${category}`} class="post-category">
        {categoryLabels[category] || category}
      </a>
      {level && (
        <span class={`level-badge level-${level}`}>
          {levelLabels[level]}
        </span>
      )}
      {trending && (
        <span class="trending-badge">Trending</span>
      )}
    </div>
    <h1>{title}</h1>
    <div class="post-meta">
      <time datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
      {updatedDate && (
        <span class="updated-date">
          Last updated:{' '}
          <time datetime={updatedDate.toISOString()}>
            {updatedDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        </span>
      )}
      <span>{readingTime} min read</span>
    </div>
  </header>

  <!-- Ad: After header, before content -->
  <div class="post-content">
    <AdSense format="auto" />
  </div>

  <article class="post-content">
    <slot />
  </article>

  <!-- Ad: After content, before lead magnet -->
  <div class="post-content">
    <AdSense format="auto" />
  </div>

  <!-- Bear Market Survival Kit Lead Magnet CTA -->
  <div class="post-content">
    <a href="/resources/bear-market-survival-kit" class="lm-cta-banner">
      <div class="lm-cta-left">
        <span class="lm-cta-badge">Free Guide</span>
        <strong>The Crypto Bear Market Survival Kit</strong>
        <span class="lm-cta-desc">7 passive income strategies that work when prices drop. Get the free PDF.</span>
      </div>
      <span class="lm-cta-arrow">&rarr;</span>
    </a>
  </div>

  {affiliateLinks.length > 0 && (
    <div class="post-content">
      {affiliateLinks.map((link) => (
        <div class="affiliate-cta">
          <h3>{link.cta || `Try ${link.name}`}</h3>
          <p>
            Sign up with our referral link and start earning passive income
            today.
          </p>
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class="cta-button"
          >
            Get Started with {link.name} &rarr;
          </a>
        </div>
      ))}
    </div>
  )}

  {tags.length > 0 && (
    <div class="post-content">
      <div class="tags">
        {tags.map((tag) => (
          <a href={`/blog?tag=${tag}`}>#{tag}</a>
        ))}
      </div>
    </div>
  )}

  <!-- Social Share Buttons -->
  <div class="post-content post-share">
    <p class="share-label">Found this useful? Share it:</p>
    <div class="share-buttons">
      <a
        href={twitterShareUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="share-btn share-btn--x"
        aria-label="Share on X (Twitter)"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
        X
      </a>
      <a
        href={redditShareUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="share-btn share-btn--reddit"
        aria-label="Share on Reddit"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
        </svg>
        Reddit
      </a>
      <a
        href={linkedinShareUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="share-btn share-btn--linkedin"
        aria-label="Share on LinkedIn"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
      <button
        class="share-btn share-btn--copy"
        aria-label="Copy link"
        data-copy-url={Astro.url.href}
        id="copy-link-btn"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        <span id="copy-link-label">Copy Link</span>
      </button>
    </div>
  </div>

  <script>
    const btn = document.getElementById('copy-link-btn');
    const label = document.getElementById('copy-link-label');
    btn?.addEventListener('click', async () => {
      const url = btn.getAttribute('data-copy-url') || window.location.href;
      await navigator.clipboard.writeText(url);
      if (label) label.textContent = 'Copied!';
      setTimeout(() => { if (label) label.textContent = 'Copy Link'; }, 2000);
    });
  </script>

  <!-- Email CTA -->
  <div class="post-content">
    <div class="post-email-cta">
      <h2>Get Smarter About Passive Income</h2>
      <p>Weekly crypto yield picks + AI income strategies. Join readers.</p>
      <p class="signup-proof">Join readers getting weekly yield picks.</p>
      <form
        action="https://subscribe-forms.beehiiv.com/1c80f432-8696-4d95-b028-aa8bd75f08ba"
        method="POST"
        target="_blank"
        class="post-email-form"
      >
        <input
          type="email"
          name="email"
          placeholder="you@example.com"
          required
        />
        <button type="submit">Get Free Tips</button>
      </form>
    </div>
  </div>

  <!-- Comments -->
  <div class="post-content">
    <div class="post-comments" style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(75, 85, 99, 0.1);">
      <h2>Join the Discussion</h2>
      <div
        id="cusdis_thread"
        data-host="https://cusdis.com"
        data-app-id="452c89df-5af8-42bc-b36a-ba3d46adc918"
        data-page-id={canonicalUrl || Astro.url.pathname}
        data-page-url={canonicalUrl || Astro.url.href}
        data-page-title={title}
        data-theme="light"
        style="min-height: 350px;"
      ></div>
      <script async defer src="https://cusdis.com/js/cusdis.es.js"></script>
    </div>
  </div>
  <style>
    :global(#cusdis_thread iframe) {
      width: 100% !important;
      min-height: 350px !important;
      border: none !important;
    }
  </style>

  <!-- Ad: Before related articles -->
  <div class="post-content">
    <AdSense format="auto" />
  </div>

  <!-- Related Articles -->
  {relatedPosts.length > 0 && (
    <div class="post-content">
      <div class="related-articles">
        <h2 class="related-heading">Keep Reading</h2>
        <div class="related-grid">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.id}`} class="related-card">
              <div class="related-card-top">
                <span class="card-category">{post.data.category}</span>
                {post.data.level && (
                  <span class={`level-badge level-${post.data.level}`}>
                    {levelLabels[post.data.level]}
                  </span>
                )}
                {post.data.trending && (
                  <span class="trending-badge">Trending</span>
                )}
              </div>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <span class="related-read-more">Read article &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}
</BaseLayout>
